---
/**
 * PROJECT DETAIL PAGE — /projects/<slug>
 *
 * Sections, in order:
 *   1. Title, tagline, status + action buttons (GitHub / live)
 *   2. Cinematic walkthrough  (the highlight — if the project has one)
 *   3. Demo video             (if the project has one)
 *   4. Overview
 *   5. Gallery                (the second highlight)
 *   6. Stack used
 *   7. Cost breakdown ($0/month table)
 *
 * All content comes from the project's file in src/data/projects/.
 */
import MainLayout from '../../layouts/MainLayout.astro';
import Lightbox from '../../components/Lightbox.astro';
import { Image } from 'astro:assets';
import { projects } from '../../data/projects';

export async function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;

if (!project) {
  return Astro.redirect('/');
}

// Resolve images + videos from src/assets/
const imageModules = import.meta.glob<{ default: ImageMetadata }>('../../assets/**/*.{png,jpg,jpeg,webp,avif}', { eager: true });
const videoModules = import.meta.glob<string>('../../assets/**/*.mp4', { eager: true, query: '?url', import: 'default' });

function getImageAsset(rel: string | undefined): ImageMetadata | undefined {
  if (!rel) return undefined;
  return imageModules[`../../assets/${rel}`]?.default;
}

function getVideoUrl(rel: string | undefined): string | undefined {
  if (!rel) return undefined;
  return videoModules[`../../assets/${rel}`];
}

const gallery = project.gallery
  .map((g) => {
    const isVideo = g.type === 'video' || /\.mp4$/i.test(g.src);
    if (isVideo) {
      return { ...g, kind: 'video' as const, url: getVideoUrl(g.src) };
    }
    return { ...g, kind: 'image' as const, asset: getImageAsset(g.src) };
  })
  .filter((g) => (g.kind === 'image' ? !!g.asset : !!g.url));

const featuredVideoUrl = project.featuredVideo ? getVideoUrl(project.featuredVideo.src) : undefined;
const statusLabel = project.status === 'live' ? 'Live' : project.status === 'in-dev' ? 'In Development' : 'Archived';
const totalTechCount = project.techGroups.reduce((acc, g) => acc + g.items.length, 0);
const liveLabel = project.liveLabel ?? 'Live demo';
---

<MainLayout title={`${project.title} · Ralph Kenneth Sonio`} description={project.tagline}>
  <article>
    <!-- HERO ================================================= -->
    <section class="detail-hero">
      <a href="/#software-engineer" class="detail-back" id="detail-back">
        <span aria-hidden="true">←</span>
        <span>All projects</span>
      </a>

      <div>
        <span class="detail-status-pill">
          <span class={`status-dot ${project.status}`}></span>
          <span>{statusLabel}</span>
        </span>

        <h1 class="detail-title">{project.title}</h1>
        <p class="detail-tagline">{project.tagline}</p>
      </div>

      <div class="detail-meta-strip">
        <div class="meta-cell">
          <span class="meta-label">Monthly cost</span>
          <span class="meta-value is-accent">{project.cost.monthlyTotal}</span>
        </div>
        <div class="meta-cell">
          <span class="meta-label">Stack</span>
          <span class="meta-value">{totalTechCount} technologies</span>
        </div>
        <div class="meta-cell">
          <span class="meta-label">Status</span>
          <span class="meta-value">
            <span class={`status-dot ${project.status}`}></span>
            {statusLabel}
          </span>
        </div>
      </div>

      <div class="detail-actions">
        {project.sourceUrl && (
          <a class="action-btn" href={project.sourceUrl} target="_blank" rel="noopener noreferrer">
            <span>GitHub</span>
            <span aria-hidden="true">↗</span>
          </a>
        )}
        {project.liveUrl && (
          <a class="action-btn is-primary" href={project.liveUrl} target="_blank" rel="noopener noreferrer">
            <span>{liveLabel}</span>
            <span aria-hidden="true">↗</span>
          </a>
        )}
      </div>
    </section>

    <!-- CINEMATIC WALKTHROUGH (highlight) ==================== -->
    {project.cinematicUrl && (
      <section class="detail-section" id="cinematic">
        <div class="section-head">
          <p class="eyebrow">Cinematic</p>
          <h2 class="section-title">Walk through the product.</h2>
          {project.cinematicCaption && <p class="section-sub">{project.cinematicCaption}</p>}
        </div>
        <div
          class="cinematic-frame"
          data-cinematic-url={project.cinematicUrl}
          data-cinematic-title={`${project.title} — interactive cinematic`}
        >
          <div class="cinematic-poster" aria-hidden="true">
            {getImageAsset(project.thumbnail) && (
              <Image
                src={getImageAsset(project.thumbnail)!}
                alt=""
                widths={[800, 1200, 1600]}
                sizes="(min-width: 900px) 1100px, 100vw"
                loading="lazy"
                decoding="async"
                class="cinematic-poster-img"
              />
            )}
            <span class="cinematic-poster-veil"></span>
            <span class="cinematic-loading" role="status" aria-live="polite">
              <span class="cinematic-loading-dot" aria-hidden="true"></span>
              <span>Loading cinematic</span>
            </span>
          </div>
          <a
            href={project.cinematicUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="cinematic-fullscreen"
            aria-label="Open cinematic in fullscreen"
          >
            <span>Fullscreen</span>
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </section>
    )}

    <!-- FEATURED VIDEO ======================================= -->
    {featuredVideoUrl && (
      <section class="detail-section" id="demo-video">
        <div class="section-head">
          <p class="eyebrow">Demo</p>
          <h2 class="section-title">See it running.</h2>
          {project.featuredVideo?.caption && <p class="section-sub">{project.featuredVideo.caption}</p>}
        </div>
        <div class="featured-video-frame">
          <video controls preload="metadata" playsinline>
            <source src={featuredVideoUrl} type="video/mp4" />
            Your browser does not support the video tag.
          </video>
        </div>
      </section>
    )}

    <!-- OVERVIEW ============================================= -->
    <section class="detail-section" id="overview">
      <div class="section-head">
        <p class="eyebrow">Overview</p>
        <h2 class="section-title">What it is.</h2>
      </div>
      <p class="detail-summary">{project.summary}</p>
    </section>

    <!-- GALLERY (highlight) ================================== -->
    {gallery.length > 0 && (
      <section class="detail-section" id="gallery">
        <div class="section-head">
          <p class="eyebrow">Gallery</p>
          <h2 class="section-title">Inside the product.</h2>
          <p class="section-sub">Click any image to enlarge. Videos play inline.</p>
        </div>

        <div class="gallery-grid">
          {gallery.map((g) => (
            g.kind === 'image' && g.asset ? (
              <div class="gallery-item" data-zoom={g.asset.src} data-caption={g.caption || project.title}>
                <Image src={g.asset} width={1280} alt={g.caption || project.title} format="avif" quality={82} loading="lazy" decoding="async" />
                {g.caption && <div class="gallery-caption">{g.caption}</div>}
              </div>
            ) : (
              <div class="gallery-item is-video">
                <video controls preload="metadata" playsinline>
                  <source src={g.url} type="video/mp4" />
                </video>
                {g.caption && <div class="gallery-caption">{g.caption}</div>}
              </div>
            )
          ))}
        </div>
      </section>
    )}

    <!-- STACK USED =========================================== -->
    <section class="detail-section" id="stack">
      <div class="section-head">
        <p class="eyebrow">Stack</p>
        <h2 class="section-title">Stack used.</h2>
      </div>
      <div class="stack-grid">
        {project.techGroups.map((group) => (
          <div class="stack-card">
            <p class="stack-card-label">{group.label}</p>
            <div class="stack-card-items">
              {group.items.map((item) => <span class="tech-chip">{item}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- COST ================================================= -->
    <section class="detail-section" id="cost">
      <div class="section-head">
        <p class="eyebrow">Cost</p>
        <h2 class="section-title">Runs at {project.cost.monthlyTotal}.</h2>
        <p class="section-sub">Every service sits on a free tier with room to spare — designed that way, not stitched together.</p>
      </div>

      <div class="cost-summary">
        <div class="head">Service</div>
        <div class="head">Free tier</div>
        <div class="head">In use</div>
        <div class="head">Headroom</div>
        {project.cost.rows.map((row) => (
          <>
            <div class="service-name" data-label="Service">{row.service}</div>
            <div data-label="Free tier">{row.freeTier}</div>
            <div data-label="In use">{row.weUse}</div>
            <div class="headroom" data-label="Headroom">{row.headroom}</div>
          </>
        ))}
      </div>

      <div class="cost-total">
        <span class="label">Monthly total</span>
        <span class="value">{project.cost.monthlyTotal}</span>
      </div>
    </section>
  </article>

  <Lightbox />

  <style is:global>
    /* Defer offscreen sections' rendering work — keeps scrolling smooth. */
    .detail-section {
      content-visibility: auto;
      contain-intrinsic-size: 0 720px;
    }
    @media (max-width: 768px) {
      .detail-section {
        contain-intrinsic-size: 0 560px;
      }
    }
  </style>

  <!-- SMART BACK BUTTON -->
  <script>
    // "All projects": if the visitor came from inside the site, go BACK in
    // history — that restores the projects list at the exact scroll position
    // they left, so picking the next project is effortless. If they landed
    // here directly (shared link, search result), fall back to the homepage
    // with the projects panel open.
    function bindBack() {
      const back = document.getElementById('detail-back');
      if (!back || back.dataset.bound === 'yes') return;
      back.dataset.bound = 'yes';
      back.addEventListener('click', (e) => {
        const st: any = history.state;
        const hasInAppHistory = st && typeof st.index === 'number' && st.index > 0;
        const cameFromHere = document.referrer && document.referrer.startsWith(window.location.origin);
        if (hasInAppHistory || (cameFromHere && window.history.length > 1)) {
          e.preventDefault();
          history.back();
        }
      });
    }
    bindBack();
    document.addEventListener('astro:page-load', bindBack);
  </script>

  <!-- CINEMATIC AUTO-LOAD (deferred so the page paints first) -->
  <script>
    function bindCinematic() {
      document.querySelectorAll<HTMLElement>('.cinematic-frame[data-cinematic-url]').forEach((frame) => {
        if (frame.dataset.bound === 'true') return;
        frame.dataset.bound = 'true';

        const url = frame.dataset.cinematicUrl;
        const title = frame.dataset.cinematicTitle || 'Interactive cinematic';
        if (!url) return;

        function injectIframe() {
          if (frame.querySelector('iframe.cinematic-iframe-active')) return;
          const poster = frame.querySelector<HTMLElement>('.cinematic-poster');
          const iframe = document.createElement('iframe');
          iframe.src = url;
          iframe.title = title;
          iframe.setAttribute('allow', 'fullscreen');
          iframe.setAttribute('allowfullscreen', 'true');
          iframe.className = 'cinematic-iframe-active';
          iframe.addEventListener('load', () => {
            iframe.classList.add('is-ready');
            if (poster) poster.classList.add('is-fading');
            setTimeout(() => poster?.remove(), 600);
          }, { once: true });
          frame.appendChild(iframe);
        }

        const schedule = (cb: () => void) => {
          if ('requestIdleCallback' in window) {
            (window as any).requestIdleCallback(cb, { timeout: 1500 });
          } else {
            setTimeout(cb, 400);
          }
        };
        if (document.readyState === 'complete') {
          schedule(injectIframe);
        } else {
          window.addEventListener('load', () => schedule(injectIframe), { once: true });
        }
      });
    }
    bindCinematic();
    document.addEventListener('astro:page-load', bindCinematic);
  </script>
</MainLayout>
