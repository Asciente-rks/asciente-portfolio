---
import CinematicLayout from '../../layouts/CinematicLayout.astro';
import { Image } from 'astro:assets';
import logoIcon from '../../assets/cinematics/system-pulse-icon.png';
---

<CinematicLayout
  title="System Pulse — Cinematic"
  brandName="System Pulse"
  brandLogoIcon={logoIcon}
  brandMarkHeight={36}
  totalSlides={8}
  fontsUrl="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
>

  <!-- SLIDE 1 — OPENING -->
  <section class="slide sp-open active" data-slide="1">
    <div class="sp-bloom bloom-tl"></div>
    <div class="sp-bloom bloom-tr"></div>
    <div class="sp-open-inner">
      <div class="sp-pre" id="openingPre">Automation &amp; health monitoring</div>
      <h1 class="sp-title" id="openingTitle">
        <span class="sp-word">System</span><!--
     --><span class="sp-word sp-accent">Pulse</span>
      </h1>
      <svg class="sp-ecg" id="openingPulse" viewBox="0 0 480 80" preserveAspectRatio="none" aria-hidden="true">
        <path class="sp-ecg-path" d="M0,40 L120,40 L140,40 L150,20 L165,60 L180,8 L200,72 L215,40 L240,40 L260,40 L270,30 L285,50 L300,40 L480,40"
              fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <div class="sp-tagline" id="openingTag">
        Built on AWS free tier. Runs forever.
      </div>
    </div>
  </section>

  <!-- SLIDE 2 — THE PROBLEM -->
  <section class="slide sp-problem" data-slide="2">
    <div class="sp-bloom bloom-tl small"></div>
    <div class="sp-problem-inner">
      <div class="sp-eyebrow">The need</div>
      <h2 class="sp-prob-line">
        <span class="sp-word">Health checks</span>
        <span class="sp-word">shouldn't be</span>
        <span class="sp-word sp-accent-amber">hobby scripts.</span>
      </h2>
      <h2 class="sp-prob-line sp-prob-line-2">
        <span class="sp-word">They should</span>
        <span class="sp-word sp-accent">last forever</span>
      </h2>
      <p class="sp-prob-note">
        Self-serve registration. Granular permissions. Real audit trails.
        The shape of a SaaS product — without renting the infrastructure.
      </p>
    </div>
  </section>

  <!-- SLIDE 3 — ONBOARD / DEMO ENTRY -->
  <section class="slide sp-login" data-slide="3">
    <div class="sp-bloom bloom-tl small"></div>
    <div class="sp-login-wrap">
      <div class="sp-card sp-login-card">
        <div class="sp-card-head">
          <div class="sp-card-icon">
            <svg viewBox="0 0 480 80" preserveAspectRatio="none">
              <path d="M0,40 L150,40 L170,15 L195,65 L220,40 L480,40"
                    fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
            </svg>
          </div>
          <h3>Welcome back</h3>
          <p>Sign in to your monitoring command.</p>
        </div>

        <div class="sp-tabs">
          <button class="sp-tab active" type="button">Sign in</button>
          <button class="sp-tab" type="button">Forgot</button>
          <button class="sp-tab" type="button">Sign up</button>
        </div>

        <div class="sp-form-row">
          <span class="sp-label">Email</span>
          <div class="sp-input">you@example.com</div>
        </div>
        <div class="sp-form-row">
          <span class="sp-label">Password</span>
          <div class="sp-input">••••••••••••</div>
        </div>

        <button class="sp-btn-primary" type="button">Sign in</button>

        <div class="sp-divider"><span>or</span></div>

        <button class="sp-btn-secondary" type="button" id="demoCta">
          <span class="sp-demo-dot" aria-hidden="true"></span>
          Try demo mode
        </button>
      </div>
    </div>
    <div class="caption">
      <div class="eyebrow">Zero-friction entry</div>
      <h2>Sign in, sign up, or peek at the demo.</h2>
      <p class="sub">Editable demo templates spawn ephemeral admin or user sessions — so reviewers see the product in seconds.</p>
    </div>
  </section>

  <!-- SLIDE 4 — REAL-TIME DASHBOARD -->
  <section class="slide sp-dash" data-slide="4">
    <div class="sp-bloom bloom-tl small"></div>
    <div class="sp-dash-wrap">
      <div class="sp-dash-head">
        <div class="sp-dash-title">
          <h2>Monitored systems</h2>
          <span class="sp-poll-pill" id="pollPill">
            <span class="sp-poll-dot"></span>
            polling · 4s
          </span>
        </div>
        <button class="sp-trigger-btn" type="button" id="triggerBtn">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          Trigger probe
        </button>
      </div>

      <div class="sp-system-list">
        <article class="sp-system">
          <span class="sp-status-dot up"></span>
          <div class="sp-system-body">
            <div class="sp-system-name">api.example.com</div>
            <div class="sp-system-meta">200 · 124 ms · checked 4s ago</div>
          </div>
          <span class="sp-status-pill up">UP</span>
        </article>
        <article class="sp-system">
          <span class="sp-status-dot up"></span>
          <div class="sp-system-body">
            <div class="sp-system-name">judgement-cut.vercel.app</div>
            <div class="sp-system-meta">200 · 412 ms · checked 4s ago</div>
          </div>
          <span class="sp-status-pill up">UP</span>
        </article>
        <article class="sp-system probing" id="probingRow">
          <span class="sp-status-dot pending"></span>
          <div class="sp-system-body">
            <div class="sp-system-name">render-app.onrender.com</div>
            <div class="sp-system-meta sp-meta-spin">SQS · attempt 2 · waking cold start…</div>
          </div>
          <span class="sp-status-pill pending">CHECKING</span>
        </article>
        <article class="sp-system">
          <span class="sp-status-dot up"></span>
          <div class="sp-system-body">
            <div class="sp-system-name">internal.lambda</div>
            <div class="sp-system-meta">200 · 87 ms · checked 12s ago</div>
          </div>
          <span class="sp-status-pill up">UP</span>
        </article>
        <article class="sp-system">
          <span class="sp-status-dot down"></span>
          <div class="sp-system-body">
            <div class="sp-system-name">legacy.cron.target</div>
            <div class="sp-system-meta">503 · 1.8 s · checked 4s ago</div>
          </div>
          <span class="sp-status-pill down">DOWN</span>
        </article>
      </div>
    </div>
    <div class="caption">
      <div class="eyebrow">Live probes</div>
      <h2>10-second polling. 4 seconds when something's in flight.</h2>
    </div>
  </section>

  <!-- SLIDE 5 — GRANULAR PERMISSIONS -->
  <section class="slide sp-perms" data-slide="5">
    <div class="sp-bloom bloom-tl small"></div>
    <div class="sp-bloom bloom-tr small"></div>
    <div class="sp-perms-wrap">
      <div class="sp-card sp-perms-card">
        <div class="sp-card-head sp-card-head-tight">
          <div class="sp-perms-pill">Edit user · admin@company</div>
          <h3>Permissions</h3>
        </div>
        <div class="sp-perm-list">
          <div class="sp-perm-row" data-perm="1">
            <div>
              <div class="sp-perm-label">canCreateSystem</div>
              <div class="sp-perm-sub">Register new monitored URLs</div>
            </div>
            <div class="sp-toggle on" aria-hidden="true"><span></span></div>
          </div>
          <div class="sp-perm-row" data-perm="2">
            <div>
              <div class="sp-perm-label">canTriggerHealthChecks</div>
              <div class="sp-perm-sub">Fire on-demand probes via SQS</div>
            </div>
            <div class="sp-toggle on" aria-hidden="true"><span></span></div>
          </div>
          <div class="sp-perm-row" data-perm="3">
            <div>
              <div class="sp-perm-label">canViewLogs</div>
              <div class="sp-perm-sub">Read the 30-day rolling history</div>
            </div>
            <div class="sp-toggle on" aria-hidden="true"><span></span></div>
          </div>
          <div class="sp-perm-row" data-perm="4">
            <div>
              <div class="sp-perm-label">canEditSystem</div>
              <div class="sp-perm-sub">Modify URL + deployment mode</div>
            </div>
            <div class="sp-toggle" aria-hidden="true"><span></span></div>
          </div>
          <div class="sp-perm-row" data-perm="5">
            <div>
              <div class="sp-perm-label">canDeleteUser</div>
              <div class="sp-perm-sub">Hard-cascade including audit trail</div>
            </div>
            <div class="sp-toggle" aria-hidden="true"><span></span></div>
          </div>
          <div class="sp-perm-row" data-perm="6">
            <div>
              <div class="sp-perm-label">canInviteMembers</div>
              <div class="sp-perm-sub">Email + tokenized activation</div>
            </div>
            <div class="sp-toggle on" aria-hidden="true"><span></span></div>
          </div>
          <div class="sp-perm-row" data-perm="7">
            <div>
              <div class="sp-perm-label">canSuspendUser</div>
              <div class="sp-perm-sub">Reason + audit notes required</div>
            </div>
            <div class="sp-toggle" aria-hidden="true"><span></span></div>
          </div>
          <div class="sp-perm-row" data-perm="8">
            <div>
              <div class="sp-perm-label">canManageOrg</div>
              <div class="sp-perm-sub">Owner-only by default</div>
            </div>
            <div class="sp-toggle" aria-hidden="true"><span></span></div>
          </div>
        </div>
      </div>
    </div>
    <div class="caption">
      <div class="eyebrow">RBAC, done right</div>
      <h2>Eight toggles. Four roles. No surprises.</h2>
    </div>
  </section>

  <!-- SLIDE 6 — ARCHITECTURE -->
  <section class="slide sp-arch" data-slide="6">
    <div class="sp-bloom bloom-tl"></div>
    <div class="sp-bloom bloom-tr small"></div>
    <div class="sp-arch-wrap">
      <div class="sp-arch-flow">
        <div class="sp-arch-node" data-arch="1">
          <div class="sp-arch-icon">⚡</div>
          <div class="sp-arch-label">Browser</div>
          <div class="sp-arch-sub">React · Vite</div>
        </div>
        <div class="sp-arch-edge"></div>
        <div class="sp-arch-node" data-arch="2">
          <div class="sp-arch-icon">λ</div>
          <div class="sp-arch-label">Lambda API</div>
          <div class="sp-arch-sub">Function URL · ESM router</div>
        </div>
        <div class="sp-arch-edge"></div>
        <div class="sp-arch-node" data-arch="3">
          <div class="sp-arch-icon">⊞</div>
          <div class="sp-arch-label">SQS Queue</div>
          <div class="sp-arch-sub">DelaySeconds · DLQ</div>
        </div>
        <div class="sp-arch-edge"></div>
        <div class="sp-arch-node" data-arch="4">
          <div class="sp-arch-icon">⟁</div>
          <div class="sp-arch-label">Health Worker</div>
          <div class="sp-arch-sub">SSRF-safe probe</div>
        </div>
        <div class="sp-arch-edge"></div>
        <div class="sp-arch-node final" data-arch="5">
          <div class="sp-arch-icon">▤</div>
          <div class="sp-arch-label">DynamoDB</div>
          <div class="sp-arch-sub">Single-table · 30-day TTL</div>
        </div>
      </div>
      <div class="sp-arch-notes">
        <div class="sp-arch-note">
          <strong>Render cold-start handling.</strong> Slow probes re-enqueue with <code>DelaySeconds=90</code> instead of sleeping in Lambda — costing ~10 s of compute instead of ~95 s.
        </div>
        <div class="sp-arch-note">
          <strong>SSRF defense.</strong> Every URL is validated against loopback, RFC1918, AWS metadata, CGNAT, and IPv6 ranges at registration <em>and</em> every probe.
        </div>
      </div>
    </div>
    <div class="caption">
      <div class="eyebrow">The pulse pipeline</div>
      <h2>Click. Queue. Probe. Persist.</h2>
    </div>
  </section>

  <!-- SLIDE 7 — $0/MONTH -->
  <section class="slide sp-cost" data-slide="7">
    <div class="sp-bloom bloom-tr"></div>
    <div class="sp-cost-wrap">
      <div class="sp-cost-list">
        <div class="sp-cost-row"><span class="sp-cost-service">AWS Lambda · two functions</span><span class="sp-cost-amount">$0</span></div>
        <div class="sp-cost-row"><span class="sp-cost-service">Amazon SQS · with DLQ</span><span class="sp-cost-amount">$0</span></div>
        <div class="sp-cost-row"><span class="sp-cost-service">DynamoDB · pay-per-request</span><span class="sp-cost-amount">$0</span></div>
        <div class="sp-cost-row"><span class="sp-cost-service">Amazon SNS · optional alerts</span><span class="sp-cost-amount">$0</span></div>
        <div class="sp-cost-row"><span class="sp-cost-service">Vercel Hobby</span><span class="sp-cost-amount">$0</span></div>
      </div>
      <div class="sp-cost-total">
        <div class="sp-cost-total-label">Monthly cost</div>
        <div class="sp-cost-total-value">$0<span class="sp-cost-total-suffix">/month</span></div>
        <div class="sp-cost-total-note">AWS free tier · perpetual</div>
      </div>
    </div>
    <div class="caption">
      <div class="eyebrow">Forever architecture</div>
      <h2>Stand up the whole stack in 3 minutes. Pay nothing.</h2>
    </div>
  </section>

  <!-- SLIDE 8 — CLOSING -->
  <section class="slide sp-end" data-slide="8">
    <div class="sp-bloom bloom-tl"></div>
    <div class="sp-bloom bloom-tr"></div>
    <div class="sp-end-inner">
      <svg class="sp-ecg sp-ecg-end" id="endPulse" viewBox="0 0 480 80" preserveAspectRatio="none" aria-hidden="true">
        <path class="sp-ecg-path" d="M0,40 L120,40 L140,40 L150,20 L165,60 L180,8 L200,72 L215,40 L240,40 L260,40 L270,30 L285,50 L300,40 L480,40"
              fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <h1 class="sp-title sp-title-end" id="endTitle">
        <span class="sp-word">System</span><span class="sp-word sp-accent">Pulse</span>
      </h1>
      <p class="sp-end-tag">A real SaaS shape, on a hobby budget.</p>
      <div class="sp-end-url">system-pulse-sn3w.vercel.app</div>
    </div>
  </section>

</CinematicLayout>

<style is:global>
  /* =========================================================
     System Pulse — dark forest / neon green / pulse-monitor theme
     ========================================================= */

  :root {
    /* Re-theme the shared chrome variables */
    --bg:         #07110d;
    --bg-deep:    #0d1a13;
    --surface:    #142b1d;
    --surface-92: #142b1deb;
    --surface-88: #142b1de0;
    --surface-84: #142b1dd6;
    --ink:        #e8f5ec;
    --muted:      #9fb8a7;
    --accent:     #50de72;
    --accent-deep:#2fc95a;
    --accent-2:   #6cef8b;
    --orange:     #ffb347;
    --stroke:     #1e3a26;
    --stroke-soft:#1e3a2666;
    --green:      #50de72;
    --display:    "Space Grotesk", "Inter", sans-serif;
    --mono:       "IBM Plex Mono", monospace;

    /* SP-specific tokens */
    --sp-bg:      #07110d;
    --sp-deep:    #0d1a13;
    --sp-surface: #142b1d;
    --sp-ink:     #e8f5ec;
    --sp-muted:   #9fb8a7;
    --sp-green:   #50de72;
    --sp-green-2: #6cef8b;
    --sp-green-d: #2fc95a;
    --sp-danger:  #ff6b6b;
    --sp-amber:   #ffb347;
  }

  body {
    background:
      radial-gradient(at 15% 15%, rgba(80, 222, 114, 0.18) 0%, transparent 50%),
      radial-gradient(at 85% 10%, rgba(31, 161, 74, 0.16) 0%, transparent 55%),
      radial-gradient(at 50% 100%, rgba(31, 161, 74, 0.10) 0%, transparent 60%),
      linear-gradient(180deg, var(--sp-bg) 0%, #0a1a12 50%, var(--sp-deep) 100%) !important;
    font-family: "Space Grotesk", "Inter", sans-serif;
    color: var(--sp-ink);
  }
  body::after {
    /* Subtle dot grid texture instead of crosshatch — feels more monitoring-dashboard */
    background-image:
      radial-gradient(circle at 1px 1px, #50de7218 1px, transparent 1px) !important;
    background-size: 32px 32px !important;
  }
  body::before {
    opacity: 0.18 !important;
  }

  /* Brand mark text — green wordmark */
  .brand-mark span {
    color: var(--sp-green-2);
    font-family: var(--display);
    text-shadow: 0 0 12px rgba(80, 222, 114, 0.4);
    letter-spacing: -0.01em;
    font-weight: 600;
  }

  /* Progress dots */
  .progress .dot { background: #e8f5ec1a; }
  .progress .dot.done { background: #50de7266; }
  .progress .dot.active {
    background: var(--sp-green);
    box-shadow: 0 0 14px rgba(80, 222, 114, 0.7);
  }

  /* Controls */
  .slide-num { color: var(--sp-muted); font-family: var(--mono); }
  .ctrl {
    background: rgba(20, 43, 29, 0.85);
    border-color: var(--stroke);
    color: var(--sp-ink);
    font-family: var(--mono);
  }
  .ctrl:hover {
    background: rgba(30, 58, 38, 0.95);
    border-color: var(--sp-green);
    color: var(--sp-green-2);
  }
  .ctrl .key {
    background: var(--sp-bg);
    border-color: var(--stroke);
    color: var(--sp-muted);
  }

  /* Mobile nav */
  .mobile-nav button {
    background: var(--sp-surface);
    border-color: var(--stroke);
    color: var(--sp-green-2);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.6);
  }
  .mobile-nav button:active {
    background: var(--sp-green);
    color: var(--sp-bg);
    border-color: var(--sp-green);
  }
  .mobile-nav .progress-mini {
    background: var(--sp-surface);
    border-color: var(--stroke);
    color: var(--sp-muted);
    font-family: var(--mono);
  }

  /* Captions */
  .caption .eyebrow {
    color: var(--sp-green-2);
    border-color: rgba(80, 222, 114, 0.3);
    background: rgba(80, 222, 114, 0.08);
    font-family: var(--mono);
    font-weight: 600;
    letter-spacing: 0.3em;
  }
  .caption h2 {
    font-family: var(--display);
    color: var(--sp-ink);
    font-weight: 600;
    letter-spacing: -0.025em;
  }
  .caption p.sub {
    color: var(--sp-muted);
    font-family: "Space Grotesk", sans-serif;
    font-weight: 400;
  }

  /* =========================================================
     Decorative blooms
     ========================================================= */
  .sp-bloom {
    position: absolute;
    pointer-events: none;
    z-index: 0;
    filter: blur(70px);
    opacity: 0.55;
    border-radius: 50%;
    will-change: transform;
  }
  .bloom-tl {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(80, 222, 114, 0.55) 0%, transparent 70%);
    top: -10%; left: -8%;
  }
  .bloom-tr {
    width: 520px; height: 520px;
    background: radial-gradient(circle, rgba(31, 161, 74, 0.5) 0%, transparent 70%);
    top: -5%; right: -10%;
  }
  .sp-bloom.small { width: 340px; height: 340px; filter: blur(50px); opacity: 0.4; }

  /* Shared bits */
  .sp-word { display: inline-block; }
  .sp-accent { color: var(--sp-green-2); margin-left: 0.18em; }
  .sp-accent-amber { color: var(--sp-amber); }
  .sp-eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--sp-green-2);
    font-weight: 600;
    margin-bottom: 22px;
    opacity: 0;
    transform: translateY(10px);
  }
  .slide.active .sp-eyebrow {
    opacity: 1; transform: translateY(0);
    transition: all 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) 0.2s;
  }

  /* =========================================================
     SLIDE 1 — Opening
     ========================================================= */
  .sp-open { flex-direction: column; }
  .sp-open-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 1100px;
    padding: 0 4cqw;
  }
  .sp-pre {
    font-family: var(--mono);
    font-size: 14px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--sp-muted);
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(10px);
  }
  .sp-title {
    font-family: var(--display);
    font-size: clamp(64px, 11cqw, 156px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--sp-ink);
    text-shadow: 0 0 50px rgba(80, 222, 114, 0.35);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
  }
  .sp-title .sp-word {
    opacity: 0;
    transform: translateY(40px);
  }
  .sp-tagline {
    margin-top: 24px;
    font-family: var(--mono);
    font-weight: 500;
    font-size: clamp(15px, 1.5cqw, 22px);
    color: var(--sp-green-2);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0;
    transform: translateY(10px);
  }
  .sp-ecg {
    margin: 20px auto;
    width: clamp(280px, 36cqw, 520px);
    height: clamp(48px, 6cqw, 80px);
    color: var(--sp-green);
    filter: drop-shadow(0 0 12px rgba(80, 222, 114, 0.5));
  }
  .sp-ecg-path {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
  }

  /* =========================================================
     SLIDE 2 — Problem
     ========================================================= */
  .sp-problem {
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding-left: 10cqw;
    padding-right: 10cqw;
  }
  .sp-problem-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1100px;
  }
  .sp-prob-line {
    font-family: var(--display);
    font-size: clamp(40px, 5.6cqw, 84px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--sp-ink);
    margin-bottom: 8px;
  }
  .sp-prob-line .sp-word {
    opacity: 0;
    transform: translateY(40px);
  }
  .sp-prob-line-2 { margin-top: 14px; color: var(--sp-muted); }
  .sp-prob-note {
    margin-top: 36px;
