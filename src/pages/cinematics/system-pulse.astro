<script is:inline>
  (() => {
    function whenReady(cb) {
      if (document.readyState === 'complete' || document.readyState === 'interactive') cb();
      else document.addEventListener('DOMContentLoaded', cb, { once: true });
    }

    whenReady(() => {
      if (typeof gsap === 'undefined') {
        console.warn('GSAP not loaded — animations skipped');
        return;
      }

      function $$(sel, root) { return (root || document).querySelectorAll(sel); }
      function $(sel, root) { return (root || document).querySelector(sel); }

      // Animate the ECG path as if it's being drawn. Re-runs on every visit
      // to slides 1 & 8.
      function drawEcg(svgEl) {
        if (!svgEl) return;
        const path = svgEl.querySelector('.sp-ecg-path');
        if (!path) return;
        const len = path.getTotalLength();
        path.style.strokeDasharray = `${len}`;
        path.style.strokeDashoffset = `${len}`;
        gsap.to(path, {
          strokeDashoffset: 0,
          duration: 1.8,
          ease: 'power2.inOut',
          delay: 0.6,
        });
      }

      // ----- SLIDE 1: OPENING -----
      function animOpen(s) {
        const words = $$('.sp-title .sp-word', s);
        gsap.fromTo($('.sp-pre', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' });
        gsap.fromTo(words, { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.9, stagger: 0.15, delay: 0.3, ease: 'expo.out' });
        drawEcg($('#openingPulse', s));
        gsap.fromTo($('.sp-tagline', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.8, delay: 2.4, ease: 'power3.out' });
      }

      // ----- SLIDE 2: PROBLEM -----
      function animProblem(s) {
        const words = $$('.sp-prob-line .sp-word', s);
        gsap.fromTo(words, { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.6, stagger: 0.08, delay: 0.4, ease: 'back.out(1.4)' });
      }

      // ----- SLIDE 3: LOGIN -----
      function animLogin(s) {
        gsap.fromTo($('.sp-login-card', s),
          { opacity: 0, y: 20, scale: 0.96 },
          { opacity: 1, y: 0, scale: 1, duration: 0.7, delay: 0.2, ease: 'power3.out', clearProps: 'transform' });
        // Pulse the demo CTA after a moment
        const demoBtn = $('#demoCta', s);
        gsap.fromTo(demoBtn,
          { boxShadow: '0 0 0 0 rgba(80, 222, 114, 0)' },
          { boxShadow: '0 0 0 8px rgba(80, 222, 114, 0)', duration: 1.4, delay: 1.2, repeat: 2, ease: 'power2.out' });
      }

      // ----- SLIDE 4: DASHBOARD -----
      function animDash(s) {
        gsap.fromTo($('.sp-dash-head', s), { opacity: 0, y: -10 },
          { opacity: 1, y: 0, duration: 0.6, delay: 0.2, ease: 'power3.out' });
        gsap.fromTo($$('.sp-system', s), { opacity: 0, x: -12 },
          { opacity: 1, x: 0, duration: 0.4, stagger: 0.08, delay: 0.4, ease: 'power3.out', clearProps: 'all' });

        // Simulate the trigger probe action a moment later
        const btn = $('#triggerBtn', s);
        const probingRow = $('#probingRow', s);
        const pollPill = $('#pollPill', s);
        setTimeout(() => {
          btn.classList.add('fired');
          if (pollPill) {
            pollPill.innerHTML = '<span class="sp-poll-dot"></span>polling · 4s';
          }
          setTimeout(() => btn.classList.remove('fired'), 1500);
        }, 1800);
      }

      // ----- SLIDE 5: PERMISSIONS -----
      function animPerms(s) {
        const rows = $$('.sp-perm-row', s);
        gsap.fromTo(rows, { opacity: 0, x: -8 },
          { opacity: 1, x: 0, duration: 0.4, stagger: 0.06, delay: 0.3, ease: 'power3.out', clearProps: 'all' });

        // Flip a toggle near the end for visual interest
        setTimeout(() => {
          const toggleableRow = rows[3]; // canEditSystem
          if (toggleableRow) {
            const toggle = toggleableRow.querySelector('.sp-toggle');
            toggle && toggle.classList.add('on');
          }
        }, 1400);
      }

      // ----- SLIDE 6: ARCHITECTURE -----
      function animArch(s) {
        const nodes = $$('.sp-arch-node', s);
        const edges = $$('.sp-arch-edge', s);
        const notes = $$('.sp-arch-note', s);

        edges.forEach((e) => e.classList.remove('lit'));
        const tl = gsap.timeline({ delay: 0.3 });
        nodes.forEach((node, i) => {
          tl.to(node, { opacity: 1, y: 0, duration: 0.4, ease: 'power3.out' }, i === 0 ? 0 : '+=.12');
          if (edges[i]) tl.add(() => edges[i].classList.add('lit'), '+=.05');
        });
        tl.to(notes, { opacity: 1, y: 0, duration: 0.6, stagger: 0.15, ease: 'power3.out' }, '+=.2');
      }

      // ----- SLIDE 7: COST -----
      function animCost(s) {
        gsap.fromTo($$('.sp-cost-row', s), { opacity: 0, x: -12 },
          { opacity: 1, x: 0, duration: 0.4, stagger: 0.1, delay: 0.3, ease: 'power3.out' });
        gsap.fromTo($('.sp-cost-total', s), { opacity: 0, scale: 0.94 },
          { opacity: 1, scale: 1, duration: 0.7, delay: 0.9, ease: 'back.out(1.5)' });
      }

      // ----- SLIDE 8: CLOSING -----
      function animEnd(s) {
        const words = $$('.sp-title .sp-word', s);
        drawEcg($('#endPulse', s));
        gsap.fromTo(words, { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.9, stagger: 0.15, delay: 0.5, ease: 'expo.out' });
        gsap.fromTo($('.sp-end-tag', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.7, delay: 1.5, ease: 'power3.out' });
        gsap.fromTo($('.sp-end-url', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.7, delay: 1.9, ease: 'power3.out' });
      }

      const sceneMap = {
        1: animOpen,
        2: animProblem,
        3: animLogin,
        4: animDash,
        5: animPerms,
        6: animArch,
        7: animCost,
        8: animEnd,
      };

      document.addEventListener('cinematic:slide-changed', (e) => {
        const { slide } = e.detail;
        const num = +slide.dataset.slide;
        const fn = sceneMap[num];
        if (fn) fn(slide);
      });
    });
  })();
</script>
