<script is:inline>
  (() => {
    function whenReady(cb) {
      if (document.readyState === 'complete' || document.readyState === 'interactive') cb();
      else document.addEventListener('DOMContentLoaded', cb, { once: true });
    }

    whenReady(() => {
      if (typeof gsap === 'undefined') return;

      function $$(sel, root) { return (root || document).querySelectorAll(sel); }
      function $(sel, root) { return (root || document).querySelector(sel); }

      // ----- SLIDE 1: BLACK OPEN -----
      function animBlackOpen(s) {
        const ember = $('#ember1', s);
        const audio = $('#audio1', s);
        const heart = $('#heartbeat1', s);
        // Heartbeat fades in first (it's the chest tightening)
        gsap.fromTo(heart, { opacity: 0 }, { opacity: 1, duration: 1.4, delay: 0.3, ease: 'power2.out' });
        // Then the audio cue (chainsaw distant)
        gsap.fromTo(audio, { opacity: 0 }, { opacity: 1, duration: 1.0, delay: 1.0, ease: 'power2.out' });
        // Finally — the lantern ignites
        gsap.fromTo(ember,
          { opacity: 0, scale: 0.3 },
          { opacity: 1, scale: 1, duration: 1.6, delay: 1.8, ease: 'power3.out' });
      }

      // ----- SLIDE 2: TITLE -----
      function animTitle(s) {
        gsap.fromTo($('#titlePre', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.8, delay: 0.3, ease: 'power2.out' });
        gsap.fromTo($$('.tll-title-main .tll-tword', s),
          { opacity: 0, y: 40, filter: 'blur(8px)' },
          { opacity: 1, y: 0, filter: 'blur(0px)', duration: 1.2, stagger: 0.25, delay: 0.7, ease: 'expo.out' });
        gsap.fromTo($('#titleRule', s), { width: 0 },
          { width: 260, duration: 0.9, delay: 2.0, ease: 'power3.out' });
        gsap.fromTo($('#titleSub', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.8, delay: 2.4, ease: 'power2.out' });
        gsap.fromTo($('#titleSub2', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.8, delay: 2.8, ease: 'power2.out' });
      }

      // ----- SLIDE 3: ENEMY 1 -----
      function animEnemy(s) {
        const art = $('.tll-enemy-art', s);
        const glint = $('#bladeGlint', s);
        gsap.fromTo($('.tll-enemy-eyebrow', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.7, delay: 0.3, ease: 'power2.out' });
        gsap.fromTo(art, { opacity: 0, scale: 0.96 },
          { opacity: 1, scale: 1, duration: 1.0, delay: 0.5, ease: 'power3.out' });
        // Blade glint sweeps across — repeats for tension
        gsap.fromTo(glint, { left: '-15%' },
          { left: '115%', duration: 2.5, delay: 1.2, ease: 'power1.inOut', repeat: 1, repeatDelay: 0.8 });
        gsap.fromTo($$('.tll-cue', s), { opacity: 0, x: -12 },
          { opacity: 1, x: 0, duration: 0.5, stagger: 0.18, delay: 1.4, ease: 'power3.out', clearProps: 'all' });
      }

      // ----- SLIDE 4: ENEMY 2 -----
      function animEnemy2(s) {
        const art = $('.tll-enemy2-art', s);
        const trail = $('#chargeTrail', s);
        const pursuer = $('#pursuer', s);
        gsap.fromTo(art, { opacity: 0, scale: 0.96 },
          { opacity: 1, scale: 1, duration: 0.9, delay: 0.3, ease: 'power3.out' });
        // The pursuer charges in
        setTimeout(() => {
          trail.classList.add('fired');
          pursuer.classList.add('charged');
        }, 1100);
        gsap.fromTo($$('.tll-stat-row', s), { opacity: 0, x: 12 },
          { opacity: 1, x: 0, duration: 0.5, stagger: 0.15, delay: 0.8, ease: 'power3.out', clearProps: 'all' });
      }

      // ----- SLIDE 5: STEALTH -----
      function animStealth(s) {
        gsap.fromTo($('.tll-stealth-frame', s), { opacity: 0, scale: 0.96 },
          { opacity: 1, scale: 1, duration: 0.9, delay: 0.3, ease: 'power3.out' });
        gsap.fromTo($('#keyPrompt', s),
          { opacity: 0, x: '-50%', y: 10 },
          { opacity: 1, x: '-50%', y: 0, duration: 0.6, delay: 1.4, ease: 'back.out(1.4)' });
        gsap.fromTo($$('.tll-snote', s), { opacity: 0, y: 8 },
          { opacity: 1, y: 0, duration: 0.5, stagger: 0.2, delay: 1.7, ease: 'power3.out', clearProps: 'all' });
      }

      // ----- SLIDE 6: KEY -----
      function animKey(s) {
        const stage = $('.tll-key-stage', s);
        const chest = $('#chest', s);
        const key = $('#keyArt', s);
        // Reset state
        chest.classList.remove('opened');
        key.classList.remove('revealed');
        gsap.fromTo(stage, { opacity: 0, scale: 0.96 },
          { opacity: 1, scale: 1, duration: 0.9, delay: 0.3, ease: 'power3.out' });
        // Open chest, then reveal key
        setTimeout(() => chest.classList.add('opened'), 900);
        setTimeout(() => key.classList.add('revealed'), 1300);
      }

      // ----- SLIDE 7: SPLIT (death / success) -----
      function animSplit(s) {
        gsap.fromTo($('#deathSide', s), { opacity: 0, x: -30 },
          { opacity: 1, x: 0, duration: 0.9, delay: 0.3, ease: 'power3.out' });
        gsap.fromTo($('#successSide', s), { opacity: 0, x: 30 },
          { opacity: 1, x: 0, duration: 0.9, delay: 0.6, ease: 'power3.out' });
        gsap.fromTo($('.tll-split-divider', s), { opacity: 0, scaleY: 0 },
          { opacity: 1, scaleY: 1, duration: 0.8, delay: 1.2, ease: 'power3.out' });
      }

      // ----- SLIDE 8: END TITLE -----
      function animEnd(s) {
        gsap.fromTo($('#endEmber', s), { opacity: 0, scale: 0.3 },
          { opacity: 1, scale: 1, duration: 1.4, ease: 'power3.out' });
        gsap.fromTo($$('.tll-end-title .tll-tword', s),
          { opacity: 0, y: 40, filter: 'blur(6px)' },
          { opacity: 1, y: 0, filter: 'blur(0px)', duration: 1.0, stagger: 0.2, delay: 0.6, ease: 'expo.out' });
        gsap.fromTo($('#endTag', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.9, delay: 1.7, ease: 'power2.out' });
        gsap.fromTo($('#endMeta', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.8, delay: 2.1, ease: 'power2.out' });
      }

      const sceneMap = {
        1: animBlackOpen,
        2: animTitle,
        3: animEnemy,
        4: animEnemy2,
        5: animStealth,
        6: animKey,
        7: animSplit,
        8: animEnd,
      };

      document.addEventListener('cinematic:slide-changed', (e) => {
        const { slide } = e.detail;
        const num = +slide.dataset.slide;
        const fn = sceneMap[num];
        if (fn) fn(slide);
      });
    });
  })();
</script>
