---
import CinematicLayout from '../../layouts/CinematicLayout.astro';
// TaskFlow has no custom logo — render brand mark text-only.
---

<CinematicLayout
  title="TaskFlow — Cinematic"
  brandName="TaskFlow"
  totalSlides={8}
  fontsUrl="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap"
>

  <!-- SLIDE 1 — OPENING -->
  <section class="slide tf-open active" data-slide="1">
    <div class="tf-bloom bloom-blue"></div>
    <div class="tf-bloom bloom-green"></div>
    <div class="tf-open-inner">
      <div class="tf-mark" id="openingMark">
        <svg viewBox="0 0 80 80" aria-hidden="true">
          <rect x="6" y="6" width="68" height="68" rx="20" fill="#2563EB"/>
          <path d="M 24 41 L 36 53 L 58 30" fill="none" stroke="#fff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="tf-pre" id="openingPre">A multi-user todo system</div>
      <h1 class="tf-title" id="openingTitle">
        <span class="tf-tword">Task</span><span class="tf-tword tf-accent">Flow.</span>
      </h1>
      <div class="tf-rule" id="openingRule"></div>
      <p class="tf-tagline" id="openingTag">Plan less. Finish more.</p>
    </div>
  </section>

  <!-- SLIDE 2 — THE PITCH -->
  <section class="slide tf-pitch" data-slide="2">
    <div class="tf-pitch-inner">
      <div class="tf-eyebrow">The honest pitch</div>
      <h2 class="tf-pitch-line">
        <span class="tf-tword">Most portfolio</span>
        <span class="tf-tword">todo apps are</span>
        <span class="tf-tword tf-strike">browser tabs.</span>
      </h2>
      <h2 class="tf-pitch-line tf-pitch-line-2">
        <span class="tf-tword">This one</span>
        <span class="tf-tword">you</span>
        <span class="tf-tword tf-accent">install</span>
        <span class="tf-tword">on your phone.</span>
      </h2>
      <p class="tf-pitch-note">
        Expo · React Native · TypeScript end-to-end. Real auth. Real JWT.
        Cloud sync to a Render-hosted Express API. Distributed as an Android APK.
      </p>
    </div>
  </section>

  <!-- SLIDE 3 — THE LOGIN (dark navy) -->
  <section class="slide tf-login" data-slide="3">
    <div class="tf-login-wrap">
      <!-- Phone frame containing the login screen -->
      <div class="tf-phone">
        <div class="tf-phone-notch"></div>
        <div class="tf-phone-screen tf-screen-dark">
          <div class="tf-dark-bloom blue"></div>
          <div class="tf-dark-bloom green"></div>
          <div class="tf-status-bar">
            <span class="tf-status-time">9:41</span>
            <span class="tf-status-icons">●●● ▴ ◐</span>
          </div>
          <div class="tf-login-card">
            <div class="tf-app-mark">
              <svg viewBox="0 0 40 40" aria-hidden="true">
                <rect x="3" y="3" width="34" height="34" rx="10" fill="#2563EB"/>
                <path d="M 12 20 L 18 26 L 29 15" fill="none" stroke="#fff" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Welcome to TaskFlow</h3>
            <p class="tf-login-sub">Plan less. Finish more.</p>
            <div class="tf-field">
              <span class="tf-field-label">Email</span>
              <div class="tf-field-input">you@example.com</div>
            </div>
            <div class="tf-field">
              <span class="tf-field-label">Password</span>
              <div class="tf-field-input">••••••••</div>
            </div>
            <button class="tf-login-btn" type="button" id="loginBtn">Sign in</button>
            <p class="tf-login-foot">No account? <span>Create one</span></p>
          </div>
        </div>
      </div>
    </div>
    <div class="caption">
      <div class="eyebrow">The login screen</div>
      <h2>Real accounts. JWT in AsyncStorage. Persistent across restarts.</h2>
    </div>
  </section>

  <!-- SLIDE 4 — THE COLD-START MOMENT (signature) -->
  <section class="slide tf-coldstart" data-slide="4">
    <div class="tf-coldstart-wrap">
      <!-- Phone showing the wake-up notice -->
      <div class="tf-phone">
        <div class="tf-phone-notch"></div>
        <div class="tf-phone-screen tf-screen-dark">
          <div class="tf-status-bar">
            <span class="tf-status-time">9:41</span>
            <span class="tf-status-icons">●●● ▴ ◐</span>
          </div>
          <div class="tf-wake-stage">
            <!-- Wake-up notice banner -->
            <div class="tf-wake-banner" id="wakeBanner">
              <div class="tf-wake-icon">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <div class="tf-wake-body">
                <div class="tf-wake-title">Waking up the server</div>
                <div class="tf-wake-sub">Render free tier · 30–60s</div>
              </div>
              <div class="tf-wake-spinner" id="wakeSpinner">
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" fill="none" stroke="#3b82f6" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="14 50"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Engineering notes -->
      <div class="tf-cold-notes">
        <div class="tf-cold-note" data-note="1">
          <span class="tf-cold-mark">⏱</span>
          <div>
            <strong>AbortController · 2-minute timeout</strong>
            <span>Gives the backend time to fully wake before giving up.</span>
          </div>
        </div>
        <div class="tf-cold-note" data-note="2">
          <span class="tf-cold-mark">↻</span>
          <div>
            <strong>retryWrapper · transient-only</strong>
            <span>Retries network failures but not validation errors.</span>
          </div>
        </div>
        <div class="tf-cold-note" data-note="3">
          <span class="tf-cold-mark">✦</span>
          <div>
            <strong>1.5s fade-in</strong>
            <span>The banner only appears once it's been slow — never as anxious noise.</span>
          </div>
        </div>
      </div>
    </div>
    <div class="caption">
      <div class="eyebrow">The honest moment</div>
      <h2>$0 hosting has consequences. We don't hide them.</h2>
    </div>
  </section>

  <!-- SLIDE 5 — THE TASKS SCREEN -->
  <section class="slide tf-tasks" data-slide="5">
    <div class="tf-tasks-wrap">
      <div class="tf-phone">
        <div class="tf-phone-notch"></div>
        <div class="tf-phone-screen tf-screen-light">
          <div class="tf-status-bar tf-status-light">
            <span class="tf-status-time">9:41</span>
            <span class="tf-status-icons">●●● ▴ ◐</span>
          </div>
          <div class="tf-task-head">
            <div class="tf-task-greeting">
              <div class="tf-task-hello">Hello, Ralph</div>
              <div class="tf-task-meta">3 of 5 done · today</div>
            </div>
            <div class="tf-task-avatar">R</div>
          </div>
          <div class="tf-task-list" id="taskList">
            <article class="tf-task done" data-task="1">
              <span class="tf-check"><span></span></span>
              <div class="tf-task-body">
                <div class="tf-task-title">Push portfolio v2 to main</div>
                <div class="tf-task-due">due yesterday</div>
              </div>
            </article>
            <article class="tf-task done" data-task="2">
              <span class="tf-check"><span></span></span>
              <div class="tf-task-body">
                <div class="tf-task-title">Reply to support thread</div>
                <div class="tf-task-due">due today</div>
              </div>
            </article>
            <article class="tf-task done" data-task="3">
              <span class="tf-check"><span></span></span>
              <div class="tf-task-body">
                <div class="tf-task-title">Update Sequelize models</div>
                <div class="tf-task-due">due Apr 14</div>
              </div>
            </article>
            <article class="tf-task" data-task="4" id="taskAnimTarget">
              <span class="tf-check"><span></span></span>
              <div class="tf-task-body">
                <div class="tf-task-title">Record cinematic voiceover</div>
                <div class="tf-task-due tf-due-soon">due in 2h</div>
              </div>
            </article>
            <article class="tf-task" data-task="5">
              <span class="tf-check"><span></span></span>
              <div class="tf-task-body">
                <div class="tf-task-title">Walk the dog</div>
                <div class="tf-task-due">no due date</div>
              </div>
            </article>
          </div>
          <button class="tf-fab" type="button">＋</button>
        </div>
      </div>
    </div>
    <div class="caption">
      <div class="eyebrow">The list</div>
      <h2>Optimistic toggles. LayoutAnimation. Server in sync.</h2>
    </div>
  </section>

  <!-- SLIDE 6 — ADD TASK FLOW -->
  <section class="slide tf-add" data-slide="6">
    <div class="tf-add-wrap">
      <div class="tf-phone">
        <div class="tf-phone-notch"></div>
        <div class="tf-phone-screen tf-screen-light">
          <div class="tf-status-bar tf-status-light">
            <span class="tf-status-time">9:41</span>
            <span class="tf-status-icons">●●● ▴ ◐</span>
          </div>
          <!-- Dimmed task list behind modal -->
          <div class="tf-task-head tf-dimmed">
            <div class="tf-task-greeting">
              <div class="tf-task-hello">Hello, Ralph</div>
              <div class="tf-task-meta">3 of 5 done</div>
            </div>
            <div class="tf-task-avatar">R</div>
          </div>
          <div class="tf-task-list tf-dimmed">
            <article class="tf-task done"><span class="tf-check"><span></span></span><div class="tf-task-body"><div class="tf-task-title">Push portfolio v2 to main</div></div></article>
            <article class="tf-task done"><span class="tf-check"><span></span></span><div class="tf-task-body"><div class="tf-task-title">Reply to support thread</div></div></article>
            <article class="tf-task done"><span class="tf-check"><span></span></span><div class="tf-task-body"><div class="tf-task-title">Update Sequelize models</div></div></article>
          </div>
          <!-- Add modal -->
          <div class="tf-modal" id="addModal">
            <div class="tf-modal-head">
              <h4>New task</h4>
            </div>
            <div class="tf-field">
              <span class="tf-field-label">Title</span>
              <div class="tf-field-input tf-field-typing" id="titleInput"></div>
            </div>
            <div class="tf-field">
              <span class="tf-field-label">Description (optional)</span>
              <div class="tf-field-input tf-multiline">Test the cinematic across 3 device sizes</div>
            </div>
            <div class="tf-field">
              <span class="tf-field-label">Due date</span>
              <div class="tf-field-pill" id="duePill">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="5" width="18" height="16" rx="2"/>
                  <line x1="8" y1="3" x2="8" y2="7"/>
                  <line x1="16" y1="3" x2="16" y2="7"/>
                  <line x1="3" y1="11" x2="21" y2="11"/>
                </svg>
                <span>Apr 17 · 6:00 PM</span>
              </div>
            </div>
            <div class="tf-modal-actions">
              <button class="tf-modal-btn ghost" type="button">Cancel</button>
              <button class="tf-modal-btn primary" type="button" id="addBtn">Add task</button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="caption">
      <div class="eyebrow">The add flow</div>
      <h2>Title. Date via native OS picker. One tap to save.</h2>
    </div>
  </section>

  <!-- SLIDE 7 — THE STACK + $0 -->
  <section class="slide tf-stack" data-slide="7">
    <div class="tf-stack-wrap">
      <div class="tf-arch">
        <div class="tf-arch-node" data-arch="1">
          <div class="tf-arch-icon">▢</div>
          <div class="tf-arch-label">Phone</div>
          <div class="tf-arch-sub">Expo · React Native</div>
        </div>
        <div class="tf-arch-edge">
          <span class="tf-edge-tag">HTTPS · JWT · retry</span>
        </div>
        <div class="tf-arch-node" data-arch="2">
          <div class="tf-arch-icon">⊞</div>
          <div class="tf-arch-label">Express 5</div>
          <div class="tf-arch-sub">Render · free web service</div>
        </div>
        <div class="tf-arch-edge">
          <span class="tf-edge-tag">Sequelize</span>
        </div>
        <div class="tf-arch-node final" data-arch="3">
          <div class="tf-arch-icon">▤</div>
          <div class="tf-arch-label">MySQL</div>
          <div class="tf-arch-sub">Aiven · free tier</div>
        </div>
      </div>

      <div class="tf-cost-card">
        <div class="tf-cost-rows">
          <div class="tf-cost-row"><span>Render · Express backend</span><span class="tf-cost-amt">$0</span></div>
          <div class="tf-cost-row"><span>Aiven · MySQL free tier</span><span class="tf-cost-amt">$0</span></div>
          <div class="tf-cost-row"><span>EAS Build · cloud APK build</span><span class="tf-cost-amt">$0</span></div>
          <div class="tf-cost-row"><span>GitHub Releases · APK distribution</span><span class="tf-cost-amt">$0</span></div>
        </div>
        <div class="tf-cost-total">
          <div class="tf-cost-total-label">Monthly</div>
          <div class="tf-cost-total-value">$0<span class="tf-cost-total-suffix">/month</span></div>
          <div class="tf-cost-total-note">No Play Store. No paid tier. No expiry.</div>
        </div>
      </div>
    </div>
    <div class="caption">
      <div class="eyebrow">The full stack</div>
      <h2>Three boxes. Two arrows. One bill of $0.</h2>
    </div>
  </section>

  <!-- SLIDE 8 — CLOSING -->
  <section class="slide tf-end" data-slide="8">
    <div class="tf-bloom bloom-blue"></div>
    <div class="tf-bloom bloom-green"></div>
    <div class="tf-end-inner">
      <div class="tf-mark" id="endMark">
        <svg viewBox="0 0 80 80" aria-hidden="true">
          <rect x="6" y="6" width="68" height="68" rx="20" fill="#2563EB"/>
          <path d="M 24 41 L 36 53 L 58 30" fill="none" stroke="#fff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h1 class="tf-title tf-title-end">
        <span class="tf-tword">Task</span><span class="tf-tword tf-accent">Flow.</span>
      </h1>
      <div class="tf-rule"></div>
      <p class="tf-end-tag">Plan less. Finish more.</p>
      <div class="tf-end-cta">
        <span class="tf-cta-icon">↓</span>
        <span class="tf-cta-text">Download APK · sideload on Android</span>
      </div>
      <div class="tf-end-meta">
        <span>Expo SDK 54</span>
        <span class="tf-meta-dot"></span>
        <span>Express 5 · MySQL</span>
        <span class="tf-meta-dot"></span>
        <span>$0/month</span>
      </div>
    </div>
  </section>

</CinematicLayout>

<style is:global>
  /* =========================================================
     TaskFlow — warm parchment + dark navy duality theme
     ========================================================= */

  :root {
    --bg:         #F4F0E8;
    --bg-deep:    #101828;
    --surface:    #FFFFFF;
    --surface-92: #FFFFFFeb;
    --surface-88: #FFFFFFe0;
    --surface-84: #FFFFFFd6;
    --ink:        #102033;
    --muted:      #667085;
    --accent:     #2563EB;
    --accent-deep:#1D4ED8;
    --accent-2:   #3b82f6;
    --orange:     #F59E0B;
    --stroke:     #E6DFD2;
    --stroke-soft:#E6DFD266;
    --green:      #16A34A;
    --display:    "Inter", "Segoe UI", system-ui, sans-serif;
    --mono:       "JetBrains Mono", ui-monospace, monospace;

    /* TaskFlow-specific */
    --tf-parch:    #F4F0E8;
    --tf-parch-2:  #F8F5EE;
    --tf-paper:    #FFFFFF;
    --tf-navy:     #101828;
    --tf-navy-2:   #1A2438;
    --tf-ink:      #102033;
    --tf-muted:    #667085;
    --tf-blue:     #2563EB;
    --tf-blue-2:   #3b82f6;
    --tf-blue-soft:#DCE7FF;
    --tf-green:    #16A34A;
    --tf-rose:     #E11D48;
    --tf-amber:    #F59E0B;
    --tf-border:   #E6DFD2;
    --tf-border-c: #EAEEF3;
  }

  body {
    background:
      radial-gradient(at 12% 12%, rgba(37, 99, 235, 0.08) 0%, transparent 50%),
      radial-gradient(at 88% 88%, rgba(22, 163, 74, 0.06) 0%, transparent 55%),
      linear-gradient(180deg, var(--tf-parch) 0%, #EEEAE0 50%, var(--tf-parch) 100%) !important;
    font-family: "Inter", system-ui, sans-serif;
    color: var(--tf-ink);
  }
  body::after { background-image: none !important; }
  body::before { opacity: 0.12 !important; }

  /* Brand mark */
  .brand-mark span {
    color: var(--tf-blue);
    font-family: var(--display);
    font-weight: 700;
    letter-spacing: -0.01em;
    font-size: 14px;
  }

  /* Progress + chrome */
  .progress .dot { background: rgba(37, 99, 235, 0.16); }
  .progress .dot.done { background: rgba(37, 99, 235, 0.5); }
  .progress .dot.active {
    background: var(--tf-blue);
    box-shadow: 0 0 12px rgba(37, 99, 235, 0.5);
  }
  .slide-num {
    color: var(--muted);
    font-family: var(--mono);
    letter-spacing: 0.2em;
  }
  .ctrl {
    background: rgba(255, 255, 255, 0.9);
    border-color: var(--tf-border);
    color: var(--tf-ink);
    font-family: var(--mono);
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.06);
  }
  .ctrl:hover {
    background: var(--surface);
    border-color: var(--tf-blue);
    color: var(--tf-blue);
  }
  .ctrl .key {
    background: var(--tf-parch);
    border-color: var(--tf-border);
    color: var(--muted);
  }
  .mobile-nav button {
    background: var(--surface);
    border-color: var(--tf-border);
    color: var(--tf-blue);
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.12);
  }
  .mobile-nav button:active {
    background: var(--tf-blue);
    color: #fff;
    border-color: var(--tf-blue);
  }
  .mobile-nav .progress-mini {
    background: var(--surface);
    border-color: var(--tf-border);
    color: var(--muted);
    font-family: var(--mono);
  }

  .caption .eyebrow {
    color: var(--tf-blue);
    border-color: rgba(37, 99, 235, 0.3);
    background: rgba(37, 99, 235, 0.06);
    font-family: var(--mono);
    font-weight: 600;
    letter-spacing: 0.32em;
  }
  .caption h2 {
    font-family: var(--display);
    color: var(--tf-ink);
    font-weight: 700;
    letter-spacing: -0.025em;
  }
  .caption p.sub { color: var(--muted); }

  /* =========================================================
     Decorative blooms
     ========================================================= */
  .tf-bloom {
    position: absolute;
    pointer-events: none;
    z-index: 0;
    filter: blur(70px);
    opacity: 0.35;
    border-radius: 50%;
    will-change: transform;
  }
  .bloom-blue {
    width: 540px; height: 540px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.55) 0%, transparent 70%);
    top: -10%; left: -8%;
  }
  .bloom-green {
    width: 460px; height: 460px;
    background: radial-gradient(circle, rgba(22, 163, 74, 0.4) 0%, transparent 70%);
    bottom: -10%; right: -8%;
  }

  .tf-tword { display: inline-block; }
  .tf-accent { color: var(--tf-blue); }
  .tf-strike { position: relative; }
  .tf-strike::after {
    content: "";
    position: absolute;
    left: -4%; right: -4%;
    top: 55%;
    height: 5px;
    background: var(--tf-blue);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;
    border-radius: 3px;
    opacity: 0.7;
  }
  .slide.active .tf-strike::after { transform: scaleX(1); }

  .tf-eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--tf-blue);
    font-weight: 600;
    margin-bottom: 22px;
    opacity: 0;
    transform: translateY(10px);
  }
  .slide.active .tf-eyebrow {
    opacity: 1; transform: translateY(0);
    transition: all 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) 0.2s;
  }

  .tf-rule {
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--tf-blue), transparent);
    margin: 24px auto;
    box-shadow: 0 0 14px rgba(37, 99, 235, 0.4);
  }

  /* =========================================================
     SLIDE 1 — Opening
     ========================================================= */
  .tf-open { flex-direction: column; }
  .tf-open-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 1100px;
    padding: 0 4cqw;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .tf-mark {
    width: clamp(60px, 7cqw, 92px);
    height: auto;
    margin-bottom: 28px;
    opacity: 0;
    transform: scale(0.7) translateY(20px);
    filter: drop-shadow(0 12px 30px rgba(37, 99, 235, 0.4));
  }
  .tf-mark svg { width: 100%; height: auto; display: block; }
  .tf-pre {
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 22px;
    opacity: 0;
    transform: translateY(10px);
  }
  .tf-title {
    font-family: var(--display);
    font-weight: 800;
    font-size: clamp(60px, 10cqw, 144px);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--tf-ink);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }
  .tf-title .tf-tword {
    opacity: 0;
    transform: translateY(40px);
  }
  .tf-tagline {
    margin-top: 4px;
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(18px, 1.8cqw, 26px);
    color: var(--muted);
    letter-spacing: 0.04em;
    opacity: 0;
    transform: translateY(10px);
  }

  /* =========================================================
     SLIDE 2 — Pitch
     ========================================================= */
  .tf-pitch {
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding-left: 10cqw;
    padding-right: 10cqw;
  }
  .tf-pitch-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1100px;
  }
  .tf-pitch-line {
    font-family: var(--display);
    font-size: clamp(40px, 6cqw, 88px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--tf-ink);
  }
  .tf-pitch-line-2 { margin-top: 10px; color: var(--muted); }
  .tf-pitch-line .tf-tword {
    opacity: 0;
    transform: translateY(40px);
  }
  .tf-pitch-note {
    margin-top: 36px;
    font-family: var(--display);
    font-weight: 400;
    color: var(--muted);
    font-size: clamp(15px, 1.35cqw, 21px);
    line-height: 1.6;
    max-width: 740px;
    opacity: 0;
    transform: translateY(10px);
  }
  .slide.active .tf-pitch-note {
    opacity: 1; transform: translateY(0);
    transition: all 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) 1.6s;
  }
  .tf-pitch .caption { display: none; }

  /* =========================================================
     SHARED — Phone frame (used in slides 3, 4, 5, 6)
     ========================================================= */
  .tf-phone {
    position: relative;
    width: clamp(280px, 30cqw, 380px);
    aspect-ratio: 9 / 19;
    background: #050810;
    border-radius: 38px;
    padding: 14px;
    box-shadow:
      0 30px 70px rgba(16, 24, 40, 0.5),
      inset 0 0 0 2px rgba(60, 70, 90, 0.5);
    z-index: 2;
  }
  .tf-phone-notch {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 96px;
    height: 22px;
    background: #050810;
    border-radius: 0 0 14px 14px;
    z-index: 3;
  }
  .tf-phone-notch::after {
    content: "";
    position: absolute;
    top: 7px;
    right: 16px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a2438, #050810);
    box-shadow: inset 0 0 0 1.5px #2a3245;
  }
  .tf-phone-screen {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 26px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .tf-screen-dark {
    background: linear-gradient(180deg, var(--tf-navy) 0%, var(--tf-navy-2) 100%);
    color: #fff;
  }
  .tf-screen-light {
    background: var(--tf-parch);
    color: var(--tf-ink);
  }
  .tf-status-bar {
    padding: 18px 22px 8px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
  }
  .tf-status-bar.tf-status-light { color: var(--muted); }
  .tf-status-time { letter-spacing: 0.02em; }
  .tf-status-icons { font-size: 10px; letter-spacing: 0.08em; }

  /* =========================================================
     SLIDE 3 — Login
     ========================================================= */
  .tf-login { flex-direction: column; }
  .tf-login-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    width: 100%;
  }
  .tf-dark-bloom {
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
    filter: blur(40px);
  }
  .tf-dark-bloom.blue {
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.5) 0%, transparent 70%);
    top: -10%; right: -20%;
  }
  .tf-dark-bloom.green {
    width: 180px; height: 180px;
    background: radial-gradient(circle, rgba(22, 163, 74, 0.35) 0%, transparent 70%);
    bottom: -8%; left: -16%;
  }
  .tf-login-card {
    flex: 1;
    margin: 24px 16px 16px;
    background: rgba(255, 255, 255, 0.98);
    border-radius: 22px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    color: var(--tf-ink);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }
  .tf-app-mark {
    width: 44px;
    margin-bottom: 4px;
  }
  .tf-app-mark svg { width: 100%; height: auto; }
  .tf-login-card h3 {
    font-family: var(--display);
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -0.02em;
    color: var(--tf-ink);
    line-height: 1.1;
  }
  .tf-login-sub {
    font-family: var(--display);
    font-size: 13px;
    color: var(--muted);
    margin-top: -8px;
    margin-bottom: 6px;
  }
  .tf-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .tf-field-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
  }
  .tf-field-input {
    padding: 11px 14px;
    background: var(--tf-parch-2);
    border: 1px solid var(--tf-border-c);
    border-radius: 12px;
    font-family: var(--display);
    font-size: 13px;
    color: var(--tf-ink);
    min-height: 18px;
  }
  .tf-field-input.tf-multiline {
    min-height: 36px;
    line-height: 1.5;
  }
  .tf-field-typing {
    color: var(--tf-ink);
    font-weight: 500;
  }
  .tf-field-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--tf-blue-soft);
    color: var(--tf-blue);
    border-radius: 8px;
    font-family: var(--display);
    font-size: 12px;
    font-weight: 600;
    align-self: flex-start;
  }
  .tf-login-btn {
    margin-top: 6px;
    padding: 13px;
    background: linear-gradient(180deg, var(--tf-blue) 0%, var(--accent-deep) 100%);
    color: #fff;
    border: 0;
    border-radius: 12px;
    font-family: var(--display);
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(37, 99, 235, 0.35);
  }
  .tf-login-foot {
    text-align: center;
    font-size: 12px;
    color: var(--muted);
    margin-top: 4px;
  }
  .tf-login-foot span {
    color: var(--tf-blue);
    font-weight: 600;
  }

  /* =========================================================
     SLIDE 4 — Cold-start (signature)
     ========================================================= */
  .tf-coldstart { flex-direction: column; }
  .tf-coldstart-wrap {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 48px;
    align-items: center;
    width: min(1100px, 92cqw);
  }
  .tf-wake-stage {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
  }
  .tf-wake-banner {
    width: 100%;
    background: linear-gradient(180deg, rgba(37, 99, 235, 0.15) 0%, rgba(37, 99, 235, 0.05) 100%);
    border: 1px solid rgba(59, 130, 246, 0.5);
    border-radius: 14px;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    backdrop-filter: blur(8px);
    box-shadow: 0 0 0 0 rgba(37, 99, 235, 0), 0 8px 24px rgba(37, 99, 235, 0.18);
    opacity: 0;
    transform: translateY(8px);
  }
  .tf-wake-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(59, 130, 246, 0.2);
    color: var(--tf-blue-2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .tf-wake-body {
    flex: 1;
    min-width: 0;
  }
  .tf-wake-title {
    font-family: var(--display);
    font-weight: 700;
    font-size: 13px;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .tf-wake-sub {
    margin-top: 2px;
    font-family: var(--mono);
    font-size: 10px;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.06em;
  }
  .tf-wake-spinner {
    flex-shrink: 0;
    animation: tf-spin 1s linear infinite;
  }
  @keyframes tf-spin {
    to { transform: rotate(360deg); }
  }

  .tf-cold-notes {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .tf-cold-note {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 18px;
    background: var(--surface);
    border: 1px solid var(--tf-border);
    border-left: 2px solid var(--tf-blue);
    border-radius: 10px;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.06);
    opacity: 0;
    transform: translateX(-12px);
  }
  .slide.active .tf-cold-note { opacity: 1; transform: translateX(0); }
  .tf-cold-mark {
    color: var(--tf-blue);
    font-size: 22px;
    line-height: 1;
    width: 24px;
    text-align: center;
    flex-shrink: 0;
    font-weight: 700;
  }
  .tf-cold-note > div:last-child {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .tf-cold-note strong {
    font-family: var(--display);
    font-weight: 700;
    font-size: 13px;
    color: var(--tf-ink);
    letter-spacing: -0.01em;
  }
  .tf-cold-note span {
    font-family: var(--display);
    font-size: 12px;
    color: var(--muted);
    line-height: 1.45;
  }

  /* =========================================================
     SLIDE 5 — Tasks screen
     ========================================================= */
  .tf-tasks { flex-direction: column; }
  .tf-tasks-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    width: 100%;
  }
  .tf-task-head {
    padding: 8px 22px 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--tf-border);
  }
  .tf-task-greeting {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .tf-task-hello {
    font-family: var(--display);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: -0.02em;
    color: var(--tf-ink);
  }
  .tf-task-meta {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .tf-task-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--tf-blue), var(--accent-deep));
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--display);
    font-weight: 700;
    font-size: 13px;
  }
  .tf-task-list {
    flex: 1;
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 7px;
    overflow: hidden;
  }
  .tf-task {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 12px;
    background: var(--surface);
    border: 1px solid var(--tf-border);
    border-radius: 12px;
    box-shadow: 0 2px 6px rgba(16, 24, 40, 0.04);
    opacity: 0;
    transform: translateX(-12px);
  }
  .slide.active .tf-task { opacity: 1; transform: translateX(0); }
  .tf-check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 6px;
    border: 2px solid var(--tf-border);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--tf-parch-2);
    transition: all 0.3s;
  }
  .tf-check span {
    width: 0;
    height: 0;
    border-radius: 2px;
    background: #fff;
    transition: all 0.3s;
  }
  .tf-task.done .tf-check {
    background: var(--tf-green);
    border-color: var(--tf-green);
    box-shadow: 0 0 10px rgba(22, 163, 74, 0.35);
  }
  .tf-task.done .tf-check span {
    width: 8px;
    height: 4px;
    border-radius: 0;
    background: transparent;
    border-left: 2px solid #fff;
    border-bottom: 2px solid #fff;
    transform: rotate(-45deg) translate(2px, -1px);
  }
  .tf-task-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .tf-task-title {
    font-family: var(--display);
    font-weight: 600;
    font-size: 13px;
    color: var(--tf-ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .tf-task.done .tf-task-title {
    color: var(--muted);
    text-decoration: line-through;
    text-decoration-color: rgba(102, 112, 133, 0.5);
  }
  .tf-task-due {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.06em;
  }
  .tf-due-soon { color: var(--tf-amber); font-weight: 700; }
  .tf-fab {
    position: absolute;
    bottom: 32px;
    right: 22px;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(180deg, var(--tf-blue), var(--accent-deep));
    color: #fff;
    border: 0;
    font-size: 26px;
    font-weight: 300;
    box-shadow: 0 12px 28px rgba(37, 99, 235, 0.4);
    cursor: pointer;
    z-index: 2;
  }

  /* =========================================================
     SLIDE 6 — Add modal
     ========================================================= */
  .tf-add { flex-direction: column; }
  .tf-add-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    width: 100%;
  }
  .tf-dimmed {
    opacity: 0.25;
    pointer-events: none;
  }
  .tf-modal {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 14px;
    background: var(--surface);
    border-radius: 22px 22px 22px 22px;
    padding: 22px 22px 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: 0 -20px 50px rgba(16, 24, 40, 0.3);
    opacity: 0;
    transform: translateY(40px);
  }
  .slide.active .tf-modal {
    opacity: 1;
    transform: translateY(0);
    transition: all 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) 0.3s;
  }
  .tf-modal-head h4 {
    font-family: var(--display);
    font-weight: 700;
    font-size: 16px;
    color: var(--tf-ink);
    letter-spacing: -0.02em;
  }
  .tf-modal-actions {
    margin-top: 6px;
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }
  .tf-modal-btn {
    padding: 9px 16px;
    border-radius: 10px;
    font-family: var(--display);
    font-weight: 700;
    font-size: 12px;
    cursor: pointer;
    border: 0;
  }
  .tf-modal-btn.ghost {
    background: transparent;
    color: var(--muted);
  }
  .tf-modal-btn.primary {
    background: var(--tf-blue);
    color: #fff;
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.3);
  }
  .tf-modal-btn.primary.fired {
    background: var(--tf-green);
    box-shadow: 0 4px 14px rgba(22, 163, 74, 0.4);
  }

  /* =========================================================
     SLIDE 7 — Stack
     ========================================================= */
  .tf-stack { flex-direction: column; }
  .tf-stack-wrap {
    position: relative;
    z-index: 2;
    width: min(1180px, 94cqw);
    display: flex;
    flex-direction: column;
    gap: 36px;
    align-items: center;
  }
  .tf-arch {
    display: flex;
    align-items: center;
    gap: 0;
    width: 100%;
    max-width: 1000px;
  }
  .tf-arch-node {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 24px 14px;
    background: var(--surface);
    border: 1px solid var(--tf-border);
    border-radius: 14px;
    box-shadow: 0 8px 24px rgba(37, 99, 235, 0.06);
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .tf-arch-node.final {
    border-color: rgba(37, 99, 235, 0.4);
    box-shadow: 0 8px 24px rgba(37, 99, 235, 0.15);
  }
  .tf-arch-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: rgba(37, 99, 235, 0.08);
    border: 1px solid rgba(37, 99, 235, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--display);
    font-size: 26px;
    color: var(--tf-blue);
  }
  .tf-arch-label {
    font-family: var(--display);
    font-weight: 700;
    font-size: 14px;
    color: var(--tf-ink);
    text-align: center;
  }
  .tf-arch-sub {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
  }
  .tf-arch-edge {
    flex: 0 0 80px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--tf-blue), transparent);
    box-shadow: 0 0 10px rgba(37, 99, 235, 0.3);
    opacity: 0;
    transition: opacity 0.6s;
    align-self: center;
    position: relative;
    transform: translateY(20px);
  }
  .tf-arch-edge.lit { opacity: 0.8; }
  .tf-edge-tag {
    position: absolute;
    top: -22px;
    left: 50%;
    transform: translateX(-50%);
    padding: 3px 10px;
    background: var(--surface);
    border: 1px solid var(--tf-border);
    border-radius: 999px;
    font-family: var(--mono);
    font-size: 9px;
    color: var(--tf-blue);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .tf-cost-card {
    width: 100%;
    max-width: 1000px;
    padding: 26px 32px;
    background:
      linear-gradient(135deg, rgba(37, 99, 235, 0.06) 0%, var(--surface) 60%);
    border: 1px solid rgba(37, 99, 235, 0.3);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
    box-shadow: 0 8px 32px rgba(37, 99, 235, 0.1);
    opacity: 0;
    transform: scale(0.96);
  }
  .tf-cost-rows {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .tf-cost-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 6px 0;
    border-bottom: 1px solid var(--stroke-soft);
    font-family: var(--mono);
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.02em;
  }
  .tf-cost-row:last-child { border-bottom: 0; }
  .tf-cost-row span:first-child { color: var(--tf-ink); font-weight: 500; }
  .tf-cost-amt {
    font-family: var(--display);
    font-weight: 700;
    font-size: 18px;
    color: var(--tf-blue);
  }
  .tf-cost-total {
    flex: 0 0 auto;
    text-align: right;
    border-left: 1px solid rgba(37, 99, 235, 0.2);
    padding-left: 28px;
  }
  .tf-cost-total-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .tf-cost-total-value {
    font-family: var(--display);
    font-weight: 800;
    font-size: clamp(40px, 5cqw, 64px);
    color: var(--tf-blue);
    text-shadow: 0 0 16px rgba(37, 99, 235, 0.3);
    line-height: 1;
    display: flex;
    align-items: baseline;
    gap: 4px;
    justify-content: flex-end;
  }
  .tf-cost-total-suffix {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 600;
    text-shadow: none;
  }
  .tf-cost-total-note {
    margin-top: 8px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--muted);
    text-transform: uppercase;
    font-weight: 500;
  }

  /* =========================================================
     SLIDE 8 — Closing
     ========================================================= */
  .tf-end { flex-direction: column; }
  .tf-end-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 1100px;
    padding: 0 4cqw;
  }
  #endMark {
    width: clamp(56px, 6.5cqw, 80px);
    margin-bottom: 22px;
  }
  .tf-title-end { font-size: clamp(48px, 8cqw, 116px); }
  .tf-end-tag {
    margin-top: 14px;
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(16px, 1.7cqw, 24px);
    color: var(--muted);
    opacity: 0;
    transform: translateY(10px);
  }
  .tf-end-cta {
    margin-top: 28px;
    padding: 14px 26px;
    background: linear-gradient(180deg, var(--tf-blue) 0%, var(--accent-deep) 100%);
    color: #fff;
    border-radius: 10px;
    font-family: var(--display);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.04em;
    box-shadow: 0 14px 32px rgba(37, 99, 235, 0.4);
    display: inline-flex;
    align-items: center;
    gap: 12px;
    opacity: 0;
    transform: translateY(10px);
  }
  .tf-cta-icon { font-size: 18px; }
  .tf-end-meta {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0;
    transform: translateY(10px);
  }
  .tf-meta-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--tf-blue);
    box-shadow: 0 0 6px rgba(37, 99, 235, 0.5);
  }
  .tf-end .caption { display: none; }

  /* Container responsive */
  @container stage (max-width: 800px) {
    .tf-coldstart-wrap { grid-template-columns: 1fr; gap: 24px; }
    .tf-arch { flex-direction: column; gap: 12px; }
    .tf-arch-edge {
      width: 2px; height: 24px;
      background: linear-gradient(180deg, transparent, var(--tf-blue), transparent);
      transform: none;
    }
    .tf-edge-tag { display: none; }
    .tf-cost-card { flex-direction: column; }
    .tf-cost-total { border-left: 0; padding-left: 0; text-align: center; }
    .tf-cost-total-value { justify-content: center; }
  }
</style>

<script is:inline>
  (() => {
    function whenReady(cb) {
      if (document.readyState === 'complete' || document.readyState === 'interactive') cb();
      else document.addEventListener('DOMContentLoaded', cb, { once: true });
    }

    whenReady(() => {
      if (typeof gsap === 'undefined') return;

      function $$(sel, root) { return (root || document).querySelectorAll(sel); }
      function $(sel, root) { return (root || document).querySelector(sel); }

      // ----- SLIDE 1: OPENING -----
      function animOpen(s) {
        const words = $$('.tf-title .tf-tword', s);
        gsap.fromTo($('#openingMark', s), { opacity: 0, scale: 0.7, y: 20 },
          { opacity: 1, scale: 1, y: 0, duration: 1.0, ease: 'expo.out' });
        gsap.fromTo($('#openingPre', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.7, delay: 0.5, ease: 'power3.out' });
        gsap.fromTo(words, { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.9, stagger: 0.15, delay: 0.8, ease: 'expo.out' });
        gsap.fromTo($('#openingRule', s), { width: 0 },
          { width: 220, duration: 0.9, delay: 1.6, ease: 'power3.out' });
        gsap.fromTo($('#openingTag', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.8, delay: 2.0, ease: 'power3.out' });
      }

      // ----- SLIDE 2: PITCH -----
      function animPitch(s) {
        const words = $$('.tf-pitch-line .tf-tword', s);
        gsap.fromTo(words, { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.6, stagger: 0.08, delay: 0.4, ease: 'back.out(1.4)' });
      }

      // ----- SLIDE 3: LOGIN (just CSS fade) -----
      function animLogin(s) {
        gsap.fromTo($('.tf-phone', s), { opacity: 0, y: 20, scale: 0.96 },
          { opacity: 1, y: 0, scale: 1, duration: 0.8, delay: 0.3, ease: 'power3.out' });
        // Pulse the sign-in button after a moment
        const btn = $('#loginBtn', s);
        if (btn) {
          gsap.fromTo(btn, { boxShadow: '0 0 0 0 rgba(37, 99, 235, 0)' },
            { boxShadow: '0 0 0 12px rgba(37, 99, 235, 0)', duration: 1.6, delay: 1.4, repeat: 1, ease: 'power2.out' });
        }
      }

      // ----- SLIDE 4: COLD START (signature) -----
      function animCold(s) {
        const phone = $('.tf-phone', s);
        const banner = $('#wakeBanner', s);
        const notes = $$('.tf-cold-note', s);

        gsap.fromTo(phone, { opacity: 0, x: -20 },
          { opacity: 1, x: 0, duration: 0.8, delay: 0.3, ease: 'power3.out' });
        // The banner fades in after the 1.5s delay (mirrors actual app behavior)
        gsap.fromTo(banner, { opacity: 0, y: 8 },
          { opacity: 1, y: 0, duration: 0.7, delay: 1.7, ease: 'power3.out' });
        gsap.fromTo(notes, { opacity: 0, x: -12 },
          { opacity: 1, x: 0, duration: 0.5, stagger: 0.18, delay: 0.9, ease: 'power3.out', clearProps: 'all' });
      }

      // ----- SLIDE 5: TASKS -----
      function animTasks(s) {
        const phone = $('.tf-phone', s);
        const tasks = $$('.tf-task', s);
        gsap.fromTo(phone, { opacity: 0, y: 20, scale: 0.96 },
          { opacity: 1, y: 0, scale: 1, duration: 0.7, delay: 0.3, ease: 'power3.out' });
        gsap.fromTo(tasks, { opacity: 0, x: -12 },
          { opacity: 1, x: 0, duration: 0.4, stagger: 0.1, delay: 0.6, ease: 'power3.out', clearProps: 'all' });

        // Then animate the 4th task being completed
        const target = $('#taskAnimTarget', s);
        if (target) {
          setTimeout(() => {
            target.classList.add('done');
          }, 2000);
        }
      }

      // ----- SLIDE 6: ADD MODAL -----
      function animAdd(s) {
        const phone = $('.tf-phone', s);
        const titleInput = $('#titleInput', s);
        const addBtn = $('#addBtn', s);
        gsap.fromTo(phone, { opacity: 0, y: 20, scale: 0.96 },
          { opacity: 1, y: 0, scale: 1, duration: 0.7, delay: 0.3, ease: 'power3.out' });

        // Simulate typing into the title field
        if (titleInput) {
          titleInput.textContent = '';
          const text = 'Record cinematic voiceover';
          let i = 0;
          const start = () => {
            const interval = setInterval(() => {
              if (i < text.length) {
                titleInput.textContent = text.slice(0, ++i) + '|';
              } else {
                titleInput.textContent = text;
                clearInterval(interval);
              }
            }, 60);
          };
          setTimeout(start, 1500);
        }

        // Fire the Add button at the end
        if (addBtn) {
          setTimeout(() => addBtn.classList.add('fired'), 4000);
        }
      }

      // ----- SLIDE 7: STACK -----
      function animStack(s) {
        const nodes = $$('.tf-arch-node', s);
        const edges = $$('.tf-arch-edge', s);
        edges.forEach((e) => e.classList.remove('lit'));

        const tl = gsap.timeline({ delay: 0.3 });
        nodes.forEach((node, i) => {
          tl.to(node, { opacity: 1, y: 0, duration: 0.4, ease: 'power3.out' }, i === 0 ? 0 : '+=.15');
          if (edges[i]) tl.add(() => edges[i].classList.add('lit'), '+=.05');
        });
        tl.to($('.tf-cost-card', s), { opacity: 1, scale: 1, duration: 0.7, ease: 'back.out(1.5)' }, '+=.3');
      }

      // ----- SLIDE 8: CLOSING -----
      function animEnd(s) {
        const words = $$('.tf-title .tf-tword', s);
        gsap.fromTo($('#endMark', s), { opacity: 0, scale: 0.7, y: 20 },
          { opacity: 1, scale: 1, y: 0, duration: 1.0, ease: 'expo.out' });
        gsap.fromTo(words, { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.9, stagger: 0.15, delay: 0.4, ease: 'expo.out' });
        gsap.fromTo($('.tf-rule', s), { width: 0 },
          { width: 220, duration: 0.9, delay: 1.4, ease: 'power3.out' });
        gsap.fromTo($('.tf-end-tag', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.7, delay: 1.8, ease: 'power3.out' });
        gsap.fromTo($('.tf-end-cta', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.7, delay: 2.2, ease: 'power3.out' });
        gsap.fromTo($('.tf-end-meta', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.7, delay: 2.6, ease: 'power3.out' });
      }

      const sceneMap = {
        1: animOpen,
        2: animPitch,
        3: animLogin,
        4: animCold,
        5: animTasks,
        6: animAdd,
        7: animStack,
        8: animEnd,
      };

      document.addEventListener('cinematic:slide-changed', (e) => {
        const { slide } = e.detail;
        const num = +slide.dataset.slide;
        const fn = sceneMap[num];
        if (fn) fn(slide);
      });
    });
  })();
</script>
