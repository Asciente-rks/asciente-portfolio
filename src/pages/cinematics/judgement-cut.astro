    padding: 18px 22px;
    background: #0e2f4adb;
    border: 1px solid var(--stroke);
    border-radius: 14px;
    backdrop-filter: blur(12px);
    box-shadow: 0 0 0 0 #5cc4ff00, 0 12px 40px #00000080;
    transition: box-shadow 0.3s;
  }
  .jc-search-bar.focused {
    border-color: #5cc4ff66;
    box-shadow: 0 0 0 4px #5cc4ff20, 0 12px 40px #5cc4ff20;
  }
  .jc-search-icon {
    color: var(--jc-cyan-2);
