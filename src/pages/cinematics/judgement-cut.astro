  }

  /* =========================================================
     SLIDE 4 — Pricing Honesty
     ========================================================= */
  .jc-honesty { flex-direction: column; }
  .jc-honesty-wrap {
    position: relative;
    z-index: 2;
    width: min(1000px, 88cqw);
    display: flex;
    flex-direction: column;
    gap: 32px;
    align-items: center;
  }
  .jc-compare {
    display: flex;
    align-items: center;
    gap: 28px;
    width: 100%;
  }
  .jc-deal-large { flex: 1; max-width: 380px; }
  .jc-deal-large .jc-deal-art { aspect-ratio: 4 / 3; }
  .jc-deal-large .jc-deal-title { font-size: 20px; }
  .jc-deal-large .jc-price-now { font-size: 28px; }
  .jc-vs {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    opacity: 0;
  }
  .jc-vs-line {
    width: 40px;
    height: 1px;
