  .jc-title-end {
    font-size: clamp(48px, 9cqw, 128px);
  }
  .jc-end-tag {
    margin-top: 28px;
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(18px, 1.8cqw, 26px);
    color: var(--ink);
    letter-spacing: 0.04em;
    opacity: 0;
    transform: translateY(10px);
  }
  .jc-end .caption { display: none; }

  /* Mobile / small viewport adjustments — rare since CSS zoom handles most. */
  @container stage (max-width: 700px) {
    .jc-deal-grid { grid-template-columns: repeat(2, 1fr); }
    .jc-compare { flex-direction: column; gap: 14px; }
    .jc-vs { flex-direction: row; }
    .jc-arch-flow { flex-direction: column; gap: 12px; }
    .jc-arch-edge { width: 2px; height: 24px; background: linear-gradient(180deg, transparent 0%, var(--jc-cyan) 50%, transparent 100%); transform: none; }
  }
</style>

<script is:inline>
  (() => {
    function whenReady(cb) {
      if (document.readyState === 'complete' || document.readyState === 'interactive') cb();
      else document.addEventListener('DOMContentLoaded', cb, { once: true });
    }

    whenReady(() => {
      if (typeof gsap === 'undefined') {
        console.warn('GSAP not loaded — animations skipped');
        return;
      }

      function $$(sel, root) { return (root || document).querySelectorAll(sel); }
      function $(sel, root) { return (root || document).querySelector(sel); }

      // ----- SLIDE 1: OPENING -----
      function animOpen(s) {
        const words = $$('.jc-title .jc-word', s);
        gsap.fromTo($('.jc-pre', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' });
        gsap.fromTo(words, { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.9, stagger: 0.18, delay: 0.3, ease: 'expo.out' });
        gsap.fromTo('#openingRule', { width: 0 },
          { width: 220, duration: 0.9, delay: 1.2, ease: 'power3.out' });
        gsap.fromTo($('.jc-tagline', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.8, delay: 1.6, ease: 'power3.out' });
      }

      // ----- SLIDE 2: PROBLEM -----
      function animProblem(s) {
        const wordsL1 = $$('.jc-prob-line .jc-word', s);
        gsap.fromTo(wordsL1, { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.6, stagger: 0.08, delay: 0.4, ease: 'back.out(1.4)' });
      }

      // ----- SLIDE 3: DASHBOARD -----
      function animDash(s) {
        gsap.fromTo($('.jc-storefront-row', s), { opacity: 0, y: -12 },
          { opacity: 1, y: 0, duration: 0.6, delay: 0.2, ease: 'power3.out' });
        gsap.fromTo($('.jc-stamp', s), { opacity: 0, y: -12 },
          { opacity: 1, y: 0, duration: 0.6, delay: 0.35, ease: 'power3.out' });
        gsap.fromTo($$('.jc-deal', s), { opacity: 0, y: 20 },
          { opacity: 1, y: 0, duration: 0.5, stagger: 0.08, delay: 0.5, ease: 'power3.out', clearProps: 'all' });
      }

      // ----- SLIDE 4: PRICING HONESTY -----
      function animHonesty(s) {
        gsap.fromTo($$('.jc-compare .jc-deal', s)[0], { opacity: 0, x: -30 },
          { opacity: 1, x: 0, duration: 0.7, delay: 0.3, ease: 'power3.out', clearProps: 'all' });
        gsap.fromTo($('.jc-vs', s), { opacity: 0, scale: 0.6 },
          { opacity: 1, scale: 1, duration: 0.6, delay: 0.7, ease: 'back.out(2)' });
        gsap.fromTo($$('.jc-compare .jc-deal', s)[1], { opacity: 0, x: 30 },
          { opacity: 1, x: 0, duration: 0.7, delay: 0.85, ease: 'power3.out', clearProps: 'all' });
      }

      // ----- SLIDE 5: LIVE SEARCH -----
      function animSearch(s) {
        const bar = $('.jc-search-bar', s);
        const input = $('#searchInput', s);
        const caret = $('#searchCaret', s);
        const results = $$('.jc-search-results .jc-deal', s);
        const text = 'hollow knight';

        bar.classList.remove('focused');
        input.textContent = '';
        gsap.set(results, { opacity: 0, y: 12 });

        let i = 0;
        function typeChar() {
          if (i < text.length) {
            input.textContent = text.slice(0, ++i);
            setTimeout(typeChar, 80 + Math.random() * 60);
          } else {
            // Hide caret after typing
            setTimeout(() => { if (caret) caret.style.display = 'none'; }, 400);
            gsap.to(results, { opacity: 1, y: 0, duration: 0.5, stagger: 0.1, delay: 0.3, ease: 'power3.out' });
          }
        }
        setTimeout(() => {
          if (caret) caret.style.display = 'inline-block';
          bar.classList.add('focused');
          setTimeout(typeChar, 200);
        }, 500);
      }

      // ----- SLIDE 6: ARCHITECTURE -----
      function animArch(s) {
        const nodes = $$('.jc-arch-node', s);
        const edges = $$('.jc-arch-edge', s);
        gsap.fromTo($('.jc-arch-time', s), { opacity: 0, y: -10 },
          { opacity: 1, y: 0, duration: 0.6, delay: 0.2, ease: 'power3.out' });

        edges.forEach((e) => e.classList.remove('lit'));
        const tl = gsap.timeline({ delay: 0.5 });
        nodes.forEach((node, i) => {
          tl.to(node, { opacity: 1, y: 0, duration: 0.4, ease: 'power3.out' }, i === 0 ? 0 : '+=.15');
          if (edges[i]) {
            tl.add(() => edges[i].classList.add('lit'), '+=.1');
          }
        });
      }

      // ----- SLIDE 7: COST -----
      function animCost(s) {
        gsap.fromTo($$('.jc-cost-row', s), { opacity: 0, x: -12 },
          { opacity: 1, x: 0, duration: 0.4, stagger: 0.12, delay: 0.3, ease: 'power3.out' });
        gsap.fromTo($('.jc-cost-total', s), { opacity: 0, scale: 0.92 },
          { opacity: 1, scale: 1, duration: 0.7, delay: 1.0, ease: 'back.out(1.6)' });
      }

      // ----- SLIDE 8: CLOSING -----
      function animEnd(s) {
        const words = $$('.jc-title .jc-word', s);
        gsap.fromTo($('.jc-end-pre', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' });
        gsap.fromTo(words, { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.9, stagger: 0.18, delay: 0.3, ease: 'expo.out' });
        gsap.fromTo($('.jc-rule', s), { width: 0 },
          { width: 220, duration: 0.9, delay: 1.2, ease: 'power3.out' });
        gsap.fromTo($('.jc-end-tag', s), { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.8, delay: 1.6, ease: 'power3.out' });
      }

      const sceneMap = {
        1: animOpen,
        2: animProblem,
        3: animDash,
        4: animHonesty,
        5: animSearch,
        6: animArch,
        7: animCost,
        8: animEnd,
      };

      document.addEventListener('cinematic:slide-changed', (e) => {
        const { slide } = e.detail;
        const num = +slide.dataset.slide;
        const fn = sceneMap[num];
        if (fn) fn(slide);
      });
    });
  })();
</script>
