    animation: jc-blink 1s infinite;
  }
  @keyframes jc-blink { 50% { opacity: 0; } }
  .jc-search-results {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .jc-deal-narrow {
    display: flex;
    align-items: center;
    gap: 14px;
