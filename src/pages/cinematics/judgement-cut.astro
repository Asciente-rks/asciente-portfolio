  .dot-green { background: var(--jc-cyan); box-shadow: 0 0 12px var(--jc-cyan); }
  .dot-amber { background: var(--jc-gold); box-shadow: 0 0 12px var(--jc-gold); }
  .jc-honesty-note:nth-child(2) strong { color: var(--jc-gold-2); }

  /* =========================================================
     SLIDE 5 — Live Search
     ========================================================= */
  .jc-search { flex-direction: column; }
  .jc-search-wrap {
    position: relative;
