  }
  .jc-deal-narrow .jc-deal-body {
    flex: 1;
    padding: 0;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
  .jc-deal-narrow .jc-deal-title { font-size: 16px; }
  .jc-deal-narrow .jc-price-now { font-size: 18px; }

  /* =========================================================
     SLIDE 6 — Architecture
     ========================================================= */
  .jc-arch { flex-direction: column; }
  .jc-arch-wrap {
    position: relative;
    z-index: 2;
    width: min(1200px, 94cqw);
    display: flex;
    flex-direction: column;
    gap: 36px;
    align-items: center;
  }
  .jc-arch-time {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    background: #0e2f4ad6;
    border: 1px solid var(--stroke);
    border-radius: 999px;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.24em;
    color: var(--jc-cyan-2);
    text-transform: uppercase;
    backdrop-filter: blur(8px);
  }
  .jc-arch-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--jc-cyan);
    box-shadow: 0 0 12px var(--jc-cyan);
    animation: jc-pulse 1.5s ease-in-out infinite;
  }
  @keyframes jc-pulse {
    0%, 100% { opacity: 0.6; transform: scale(0.85); }
    50% { opacity: 1; transform: scale(1.15); }
  }
  .jc-arch-flow {
    display: flex;
    align-items: center;
    gap: 0;
    width: 100%;
  }
  .jc-arch-node {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 20px 12px;
    background: linear-gradient(180deg, #0e2f4ad6 0%, #0a2136d6 100%);
    border: 1px solid var(--stroke);
    border-radius: 14px;
    box-shadow: 0 12px 32px #00000080;
    backdrop-filter: blur(12px);
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .jc-arch-node.final {
    border-color: #5cc4ff44;
    box-shadow: 0 12px 32px #5cc4ff20, 0 0 0 1px #5cc4ff22 inset;
  }
  .jc-arch-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: linear-gradient(180deg, #164f72, #0e2f4a);
    border: 1px solid #5cc4ff33;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--display);
    font-size: 22px;
    color: var(--jc-cyan-2);
    box-shadow: 0 0 18px #5cc4ff30 inset;
  }
  .jc-arch-label {
    font-family: var(--display);
    font-weight: 700;
    font-size: 14px;
    color: var(--ink);
    text-align: center;
    line-height: 1.2;
  }
  .jc-arch-sub {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--jc-steel);
    text-align: center;
  }
  .jc-arch-edge {
    flex: 0 0 32px;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--jc-cyan) 50%, transparent 100%);
    opacity: 0;
    transition: opacity 0.6s;
    align-self: center;
    transform: translateY(28px); /* offset to align with node centers */
  }
  .jc-arch-edge.lit { opacity: 0.8; }

  /* =========================================================
     SLIDE 7 — Cost
     ========================================================= */
  .jc-cost { flex-direction: column; }
  .jc-cost-wrap {
    position: relative;
    z-index: 2;
    width: min(720px, 78cqw);
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .jc-cost-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .jc-cost-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 22px;
    background: #0e2f4ad6;
    border: 1px solid var(--stroke);
    border-radius: 12px;
    backdrop-filter: blur(8px);
    opacity: 0;
    transform: translateX(-12px);
  }
  .jc-cost-service {
    font-family: var(--mono);
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 0.04em;
    color: var(--ink);
  }
  .jc-cost-amount {
    font-family: var(--display);
    font-weight: 700;
    font-size: 24px;
    color: var(--jc-cyan-2);
    text-shadow: 0 0 12px #5cc4ff40;
  }
  .jc-cost-total {
    margin-top: 10px;
    padding: 26px 32px;
    background: linear-gradient(135deg, #164f72 0%, #0e2f4a 50%, #061625 100%);
    border: 1px solid #5cc4ff55;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 0 60px #5cc4ff25, 0 18px 60px #00000080;
    opacity: 0;
    transform: scale(0.92);
  }
  .jc-cost-total-label {
    font-family: var(--mono);
    font-size: 14px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--jc-steel);
    font-weight: 700;
  }
  .jc-cost-total-value {
    font-family: var(--display);
    font-weight: 900;
    font-size: clamp(48px, 6cqw, 86px);
    color: var(--jc-gold-2);
    text-shadow: 0 0 28px #d4b06c80;
    line-height: 1;
    display: flex;
    align-items: baseline;
    gap: 4px;
  }
  .jc-cost-total-suffix {
    font-family: var(--mono);
    font-size: 16px;
    color: var(--jc-steel);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    text-shadow: none;
  }

  /* =========================================================
     SLIDE 8 — Closing
     ========================================================= */
  .jc-end { flex-direction: column; }
  .jc-end-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .jc-end-pre {
    font-family: var(--mono);
    font-size: 14px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--jc-cyan-2);
    margin-bottom: 24px;
    text-shadow: 0 0 12px #5cc4ff60;
    opacity: 0;
    transform: translateY(10px);
