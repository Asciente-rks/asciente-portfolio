---
import MainLayout from '../layouts/MainLayout.astro';
import Terminal from '../components/Terminal.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { Image } from 'astro:assets';
import { projects } from '../data/projects';
import GradPicSrc from '../assets/GradPic_Sonio.jpg';

// Lazy-resolved imports for project thumbnails.
const thumbModules = import.meta.glob<{ default: ImageMetadata }>('../assets/**/*.{png,jpg,jpeg,webp,avif}', { eager: true });

function getThumb(rel: string | undefined): ImageMetadata | undefined {
  if (!rel) return undefined;
  const key = `../assets/${rel}`;
  return thumbModules[key]?.default;
}

const liveProjects = projects.filter((p) => p.status === 'live');
const totalProjects = projects.length;

// Real skills, sourced from author's GitHub bio. 9 categories.
const stackGroups = [
  {
    label: 'Backend & Logic',
    items: ['Node.js', 'Express', 'Sequelize', 'ASP.NET Core', 'Spring Boot', 'Spring Data JPA', 'Tauri', 'Serverless Framework', 'Fastify'],
  },
  {
    label: 'Languages',
    items: ['TypeScript', 'JavaScript', 'C# (.NET)', 'Java', 'Python', 'Rust'],
  },
  {
    label: 'Frontend & Mobile',
    items: ['React', 'React Native (Expo)', 'Tailwind CSS', 'Astro'],
  },
  {
    label: 'AWS Ecosystem',
    items: ['Lambda', 'DynamoDB', 'S3', 'SQS', 'SNS', 'CloudWatch', 'CloudFormation', 'Amplify', 'API Gateway'],
  },
  {
    label: 'Database & Storage',
    items: ['TiDB Cloud', 'DynamoDB', 'Aiven', 'MySQL', 'MongoDB', 'Cloudflare R2', 'S3'],
  },
  {
    label: 'Security & Auth',
    items: ['JWT', 'Bcrypt', 'RBAC', 'Spring Security', 'OAuth'],
  },
  {
    label: 'Deployment & Ops',
    items: ['EAS', 'Render', 'Vercel', 'AWS', 'Ngrok'],
  },
  {
    label: 'QA & Architecture',
    items: ['ISO/IEC 25010', 'Postman', 'Manual Testing', 'C4 Model'],
  },
  {
    label: 'Tooling & IDEs',
    items: ['Figma', 'VS Code', 'Visual Studio', 'Cursor', 'Eclipse'],
  },
];
---

<MainLayout
  title="Ralph Sonio · Cloud-Native Backend & QA Engineer"
  description="Cloud-Native Backend Engineer & Quality Assurance Tester. Selected work, architecture notes, and case studies."
>
  <!-- HERO ===================================================== -->
  <section class="hero" id="about">
    <div class="hero-grid">
      <div class="profile-card">
        <Image src={GradPicSrc} width={400} alt="Ralph Sonio" class="profile-img" format="avif" quality={88} />
        <div class="profile-meta">
          <div class="profile-meta-row">
            <span>name</span>
            <strong>R. K. F. Sonio</strong>
          </div>
          <div class="profile-meta-row">
            <span>role</span>
            <strong>Backend · QA</strong>
          </div>
          <div class="profile-meta-row">
            <span>focus</span>
            <strong>Cloud Native</strong>
          </div>
          <div class="profile-meta-row">
            <span>status</span>
            <span style="color: var(--status-live); display:inline-flex; align-items:center; gap:0.4rem;">
              <span class="status-dot live" style="position:relative; display:inline-block;"></span>
              Available
            </span>
          </div>
        </div>
      </div>

      <div>
        <p class="eyebrow">~/portfolio · v2.0</p>
        <h1 class="hero-name" style="margin-top: 1rem;">
          Ralph Kenneth<br />Sonio
        </h1>
        <p class="hero-tagline">
          Cloud-Native Backend Engineer · Quality Assurance Tester
        </p>
        <p class="hero-bio">
          I architect <strong style="color: var(--fg)">scalable, type-safe systems</strong> and enforce <strong style="color: var(--fg)">high-availability standards</strong> through rigorous Quality Assurance. My focus is on cloud-native infrastructure, event-driven architecture, and production-grade stability. {totalProjects} projects total · {liveProjects.length} live in production · every one of them runs at <strong style="color: var(--accent)">$0/month</strong>.
        </p>

        <div style="margin-top: 1rem;">
          <Terminal />
        </div>
      </div>
    </div>
  </section>

  <!-- STACK ==================================================== -->
  <section class="projects-section" id="stack" style="margin-top: 6rem;">
    <div class="projects-header">
      <p class="eyebrow">02 · technical expertise</p>
      <h2 class="section-title">The toolkit, opinionated.</h2>
      <div class="meta-line">
        <span>{`stack.json :: ${stackGroups.length} categories · ${stackGroups.reduce((a, g) => a + g.items.length, 0)} entries`}</span>
        <span style="color: var(--accent);">production-grade stability</span>
      </div>
    </div>

    <div class="stack-grid">
      {stackGroups.map((group) => (
        <div class="stack-card">
          <p class="stack-card-label">{group.label}</p>
          <div class="stack-card-items">
            {group.items.map((item) => <span class="tech-chip">{item}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- PROJECTS ================================================= -->
  <section class="projects-section" id="projects">
    <div class="projects-header">
      <p class="eyebrow">03 · projects</p>
      <h2 class="section-title">Selected work.</h2>
      <div class="meta-line">
        <span>{`projects.ls :: ${totalProjects} entries · ${liveProjects.length} live · ${projects.filter((p) => p.status === 'in-dev').length} in development`}</span>
        <span>last_updated: {new Date().getFullYear()}</span>
      </div>
    </div>

    <div class="projects-grid">
      {projects.map((project, i) => (
        <ProjectCard project={project} thumbSrc={getThumb(project.thumbnail)} index={i} />
      ))}
    </div>
  </section>
</MainLayout>
