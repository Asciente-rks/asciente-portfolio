---
import MainLayout from '../layouts/MainLayout.astro';
import Terminal from '../components/Terminal.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { Image } from 'astro:assets';
import { projects } from '../data/projects';
import GradPicSrc from '../assets/GradPic_Sonio.jpg';

// Lazy-resolved imports for project thumbnails.
// Returns ImageMetadata for use with the <Image /> component.
const thumbModules = import.meta.glob<{ default: ImageMetadata }>('../assets/**/*.{png,jpg,jpeg,webp,avif}', { eager: true });

function getThumb(rel: string | undefined): ImageMetadata | undefined {
  if (!rel) return undefined;
  const key = `../assets/${rel}`;
  return thumbModules[key]?.default;
}

// Groupings for the projects strip
const liveProjects = projects.filter((p) => p.status === 'live');
const totalProjects = projects.length;

// Tech stack list for the "stack" section
const stackGroups = [
  {
    label: 'Cloud + Serverless',
    items: ['AWS Lambda', 'API Gateway', 'DynamoDB', 'SQS', 'SNS', 'Cloudflare R2', 'Vercel'],
  },
  {
    label: 'Languages + Runtime',
    items: ['TypeScript', 'Node.js', 'Python', 'Java', 'C#', 'Rust (Tauri)'],
  },
  {
    label: 'Web + Mobile',
    items: ['React 18/19', 'Vite', 'Tailwind 3/4', 'Astro', 'React Native (Expo)', 'Tauri 2'],
  },
  {
    label: 'Data',
    items: ['TiDB Cloud', 'MySQL', 'DynamoDB single-table', 'Sequelize', 'Redis (Upstash)'],
  },
  {
    label: 'Tooling + CI/CD',
    items: ['GitHub Actions', 'Serverless Framework', 'EAS Build', 'Scrapy', 'node-cron'],
  },
];
---

<MainLayout
  title="Ralph Sonio · Cloud-Native Backend & QA Engineer"
  description="Selected work, architecture notes, and case studies — every project ships at $0/month on free tiers."
>
  <!-- HERO ===================================================== -->
  <section class="hero" id="about">
    <div class="hero-grid">
      <div class="profile-card reveal">
        <Image src={GradPicSrc} width={400} alt="Ralph Sonio" class="profile-img" format="avif" quality={88} />
        <div class="profile-meta">
          <div class="profile-meta-row">
            <span>name</span>
            <strong>R. K. F. Sonio</strong>
          </div>
          <div class="profile-meta-row">
            <span>role</span>
            <strong>Backend · QA</strong>
          </div>
          <div class="profile-meta-row">
            <span>focus</span>
            <strong>Cloud Native</strong>
          </div>
          <div class="profile-meta-row">
            <span>status</span>
            <span style="color: var(--status-live); display:inline-flex; align-items:center; gap:0.4rem;">
              <span class="status-dot live" style="position:relative; display:inline-block;"></span>
              Available
            </span>
          </div>
        </div>
      </div>

      <div>
        <p class="eyebrow reveal">~/portfolio · v2.0</p>
        <h1 class="hero-name reveal" style="margin-top: 1rem;">
          Ralph Kenneth<br />Sonio
        </h1>
        <p class="hero-tagline reveal">
          ./cloud-native-backend.run · ./quality-assurance-tester.run
        </p>
        <p class="hero-bio reveal">
          I design serverless backends and ship them on free tiers. {totalProjects} projects total · {liveProjects.length} live in production · every one of them runs at <strong style="color: var(--accent)">$0/month</strong>. AWS Lambda, DynamoDB, TiDB, Tauri, and React are my daily kit.
        </p>

        <div class="reveal" style="margin-top: 1rem;">
          <Terminal />
        </div>
      </div>
    </div>
  </section>

  <!-- STACK ==================================================== -->
  <section class="projects-section" id="stack" style="margin-top: 6rem;">
    <div class="projects-header reveal">
      <p class="eyebrow">02 · stack</p>
      <h2 class="section-title">The toolkit, opinionated.</h2>
      <div class="meta-line">
        <span>{`stack.json :: ${stackGroups.reduce((a, g) => a + g.items.length, 0)} entries`}</span>
        <span style="color: var(--accent);">$0/month forever</span>
      </div>
    </div>

    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem;">
      {stackGroups.map((group) => (
        <div class="reveal" style="border:1px solid var(--border); border-radius: 14px; padding: 1.25rem 1.4rem; background: var(--bg-elev);">
          <p style="font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; text-transform:uppercase; letter-spacing: 0.18em; color: var(--fg-muted); margin-bottom: 0.85rem;">
            {group.label}
          </p>
          <div style="display:flex; flex-wrap: wrap; gap: 0.4rem;">
            {group.items.map((item) => <span class="tech-chip">{item}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- PROJECTS ================================================= -->
  <section class="projects-section" id="projects">
    <div class="projects-header reveal">
      <p class="eyebrow">03 · projects</p>
      <h2 class="section-title">Selected work.</h2>
      <div class="meta-line">
        <span>{`projects.ls :: ${totalProjects} entries · ${liveProjects.length} live · ${projects.filter((p) => p.status === 'in-dev').length} in development`}</span>
        <span>last_updated: {new Date().getFullYear()}</span>
      </div>
    </div>

    <div class="projects-grid stagger">
      {projects.map((project, i) => (
        <ProjectCard project={project} thumbSrc={getThumb(project.thumbnail)} index={i} />
      ))}
    </div>
  </section>
</MainLayout>
