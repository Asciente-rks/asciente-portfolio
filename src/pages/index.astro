            <span class="tech-chip">SQL Server</span>
          </div>
          <div class="card-actions">
            <a href="#" class="card-action-btn">Source Code</a>
            <a href="#" class="card-action-btn">Live Demo</a>
          </div>
        </div>
      </article>

      <article class="group project-card overflow-hidden rounded-3xl border border-black bg-white/95 p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg" role="button" tabindex="0" onclick="if (!event.target.closest('a')) window.location.href='/projects/the-last-light'" onkeydown="if (event.key === 'Enter') window.location.href='/projects/the-last-light'">
