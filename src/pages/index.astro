---
/**
 * HOMEPAGE — composed entirely from components:
 *
 *   Hero                → photo, name, role line, summary (src/data/site.ts)
 *   RoleSelector        → "Which role?" buttons + both role panels
 *   ExperienceSection   → timeline (src/data/experience.ts)
 *   CertificatesSection → certificate wall (src/data/certificates.ts)
 *
 * The contact footer is part of the layout.
 * To change content, edit the data files — not this page.
 */
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import RoleSelector from '../components/RoleSelector.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import CertificatesSection from '../components/CertificatesSection.astro';
import Lightbox from '../components/Lightbox.astro';
import { siteConfig } from '../data/site';
---

<MainLayout title={siteConfig.meta.title} description={siteConfig.meta.description}>
  <Hero />
  <RoleSelector />
  <ExperienceSection />
  <CertificatesSection />
  <Lightbox />
</MainLayout>
