---
/**
 * ProjectCard — one project tile in the projects grid.
 * The whole card is clickable and opens the project page.
 * The content comes from the project's file in src/data/projects/.
 */
import { Image } from 'astro:assets';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  thumbSrc?: ImageMetadata;
}

const { project, thumbSrc } = Astro.props;
const statusLabel = project.status === 'live' ? 'Live' : project.status === 'in-dev' ? 'In Development' : 'Archived';
const liveLabel = project.liveLabel ?? 'Live demo';
const detailHref = `/projects/${project.slug}`;
---

<article class="project-card" data-href={detailHref} tabindex="0" role="link" aria-label={`Open ${project.title}`}>
  <a class="project-card-main" href={detailHref}>
    <div class="project-card-cover">
      {thumbSrc ? (
        <Image src={thumbSrc} width={960} alt={`${project.title} screenshot`} format="avif" quality={80} loading="lazy" decoding="async" />
      ) : (
        <div class="cover-placeholder">
          <span>{project.title}</span>
        </div>
      )}
      <div class="project-card-overlay-tag">
        <span class={`status-dot ${project.status}`}></span>
        <span>{statusLabel}</span>
      </div>
    </div>

    <div class="project-card-body">
      <h3 class="project-card-title">{project.title}</h3>
      <p class="project-card-summary">{project.tagline}</p>
      <div class="project-card-tech">
        {project.tech.slice(0, 5).map((t) => <span class="tech-chip">{t}</span>)}
        {project.tech.length > 5 && <span class="tech-chip is-more">+{project.tech.length - 5}</span>}
      </div>
    </div>
  </a>

  <div class="project-card-actions">
    {project.sourceUrl && (
      <a class="action-btn is-small" href={project.sourceUrl} target="_blank" rel="noopener noreferrer">
        <span>GitHub</span>
        <span aria-hidden="true">↗</span>
      </a>
    )}
    {project.liveUrl && (
      <a class="action-btn is-small" href={project.liveUrl} target="_blank" rel="noopener noreferrer">
        <span>{liveLabel}</span>
        <span aria-hidden="true">↗</span>
      </a>
    )}
  </div>
</article>

<script>
  import { navigate } from 'astro:transitions/client';

  // Make the whole card clickable (through the client router, so the
  // browser Back button returns to the exact same scroll position).
  function bindCards() {
    document.querySelectorAll<HTMLElement>('article.project-card[data-href]').forEach((card) => {
      if (card.dataset.bound === 'yes') return;
      card.dataset.bound = 'yes';
      const href = card.dataset.href;
      if (!href) return;

      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('a, button')) return;
        navigate(href);
      });

      card.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter') {
          const target = e.target as HTMLElement;
          if (target.closest('a, button')) return;
          navigate(href);
        }
      });
    });
  }
  bindCards();
  document.addEventListener('astro:page-load', bindCards);
</script>
