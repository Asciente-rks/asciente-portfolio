---
import { projects } from '../data/projects';
import {
  terminalIntro,
  terminalToolkit,
  terminalToolkitFooter,
  terminalPromptPrefix,
  terminalWindowTitle,
  terminalHelp,
} from '../data/terminal';

const projectIndex = projects.map((p) => ({ slug: p.slug, label: p.title }));
const promptPrefix = terminalPromptPrefix;
---

<div class="terminal-stack">
  <div class="cmd-window">
    <div class="cmd-header">
      <div class="cmd-buttons">
        <span class="cmd-btn" style="background:#ff5f56"></span>
        <span class="cmd-btn" style="background:#ffbd2e"></span>
        <span class="cmd-btn" style="background:#27c93f"></span>
      </div>
      <div class="cmd-title">{terminalWindowTitle}</div>
      <div style="width:36px"></div>
    </div>
    <div class="cmd-body">
      <div id="cmd-content" class="code-font" aria-live="polite"></div>
    </div>
  </div>

  <aside class="terminal-tip">
    <h4>quick toolkit</h4>
    {terminalToolkit.map((entry) => (
      <p><strong>{entry.command}</strong> · {entry.description}</p>
    ))}
    <p style="margin-top:0.85rem" set:html={terminalToolkitFooter}></p>
  </aside>
</div>

<script type="module" define:vars={{ projectIndex, terminalIntro, terminalHelp, promptPrefix }}>
  const projects = projectIndex;
  const projectRoutes = Object.fromEntries(projects.map((p) => [p.label.toLowerCase(), `/projects/${p.slug}`]));
  const projectNames = projects.map((p) => p.label);
  let selectedProjectIndex = -1;

  const intro = terminalIntro;
  const helpLines = terminalHelp;

  const container = document.getElementById('cmd-content');
  let isTyping = false;
  let stopTyping = false;
  let userHasInteracted = false;

  function escapeHtml(s) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function focusInputSafely(input) {
    if (!input || typeof input.focus !== 'function') return;
    if (!userHasInteracted) return;
    try {
      input.focus({ preventScroll: true });
    } catch {
      input.focus();
    }
  }

  function scrollTerminalToBottom() {
    if (container) container.scrollTop = container.scrollHeight;
  }

  function createPrompt() {
    const prompt = document.createElement('div');
    prompt.className = 'line cmd-prompt-line';

    const prefix = document.createElement('span');
    prefix.className = 'prompt-prefix';
    prefix.textContent = promptPrefix;
    prompt.appendChild(prefix);

    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'cmd-input';
    input.spellcheck = false;
    input.autocomplete = 'off';

    input.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
        event.preventDefault();
        if (event.key === 'ArrowDown') {
          selectedProjectIndex = selectedProjectIndex < projectNames.length - 1 ? selectedProjectIndex + 1 : 0;
        } else {
          selectedProjectIndex = selectedProjectIndex > 0 ? selectedProjectIndex - 1 : projectNames.length - 1;
        }
        input.value = `cd ${projectNames[selectedProjectIndex]}`;
        return;
      }

      if (event.key !== 'Enter') return;
      event.preventDefault();
      const command = input.value.trim();
      selectedProjectIndex = -1;
      input.disabled = true;

      const cmdLower = command.toLowerCase();

      if (cmdLower === '' || cmdLower === 'help') {
        helpLines.forEach((line) => appendLine(line));
        nextPrompt();
        return;
      }

      if (cmdLower === 'ls') {
        projects.forEach((project) => appendLine(`▸ ${project.label}`));
        nextPrompt();
        return;
      }

      if (cmdLower === 'clear') {
        container.innerHTML = '';
        const newPrompt = createPrompt();
        container.appendChild(newPrompt);
        focusInputSafely(newPrompt.querySelector('input'));
        return;
      }

      if (cmdLower === 'about' || cmdLower === 'stack' || cmdLower === 'contact') {
        const target = document.getElementById(cmdLower);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          appendLine(`scrolling to ${cmdLower}…`);
        } else {
          appendLine(`section "${cmdLower}" not found`);
        }
        nextPrompt();
        return;
      }

      if (cmdLower.startsWith('cd ')) {
        const targetName = command.slice(3).trim();
        const route = projectRoutes[targetName.toLowerCase()];
        if (route) {
          appendLine(`opening ${targetName}…`);
          setTimeout(() => (window.location.href = route), 480);
          return;
        }
      }

      appendLine(`The system cannot find the path specified: ${command}`);
      nextPrompt();
    });

    function appendLine(text) {
      const line = document.createElement('div');
      line.className = 'line';
      line.textContent = text;
      container.appendChild(line);
    }

    function nextPrompt() {
      const next = createPrompt();
      container.appendChild(next);
      focusInputSafely(next.querySelector('input'));
      scrollTerminalToBottom();
    }

    prompt.appendChild(input);
    return prompt;
  }

  async function typeLines(target, lines, charDelay = 18, lineDelay = 220) {
    isTyping = true;
    stopTyping = false;
    const cancel = () => (stopTyping = true);
    window.addEventListener('keydown', cancel, { once: true });

    for (const text of lines) {
      const div = document.createElement('div');
      div.className = 'line';
      target.appendChild(div);
      for (let i = 0; i <= text.length; i++) {
        if (stopTyping) break;
        div.innerHTML = escapeHtml(text.slice(0, i)) + '<span class="caret"></span>';
        await new Promise((r) => setTimeout(r, charDelay));
      }
      div.innerHTML = escapeHtml(text);
      if (stopTyping) continue;
      await new Promise((r) => setTimeout(r, lineDelay));
    }

    isTyping = false;
    target.appendChild(createPrompt());
    scrollTerminalToBottom();
  }

  function markInteracted() {
    if (userHasInteracted) return;
    userHasInteracted = true;
    const lastInput = container?.querySelector('input.cmd-input:not([disabled])');
    if (lastInput) focusInputSafely(lastInput);
  }
  container?.addEventListener('click', markInteracted);
  container?.addEventListener('focusin', markInteracted);
  document.querySelector('.cmd-window')?.addEventListener('click', markInteracted);

  setTimeout(() => typeLines(container, intro, 14, 180), 250);
</script>
