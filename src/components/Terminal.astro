---
import { projects } from '../data/projects';
import {
  terminalIntro,
  terminalToolkit,
  terminalToolkitFooter,
  terminalPromptPrefix,
  terminalWindowTitle,
  terminalHelp,
} from '../data/terminal';

const projectIndex = projects.map((p) => ({ slug: p.slug, label: p.title }));
const promptPrefix = terminalPromptPrefix;
---

<div class="terminal-stack">
  <div class="cmd-window">
    <div class="cmd-header">
      <div class="cmd-buttons">
        <span class="cmd-btn" style="background:#ff5f56"></span>
        <span class="cmd-btn" style="background:#ffbd2e"></span>
        <span class="cmd-btn" style="background:#27c93f"></span>
      </div>
      <div class="cmd-title">{terminalWindowTitle}</div>
      <button
        type="button"
        class="cmd-replay"
        data-cmd-replay
        aria-label="Replay terminal animation"
        title="Replay"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 12a9 9 0 1 0 3-6.7" />
          <path d="M3 4v5h5" />
        </svg>
      </button>
    </div>
    <div class="cmd-body">
      <div id="cmd-content" class="code-font" aria-live="polite"></div>
    </div>
  </div>

  <aside class="terminal-tip">
    <h4>quick toolkit</h4>
    {terminalToolkit.map((entry) => (
      <p><strong>{entry.command}</strong> · {entry.description}</p>
    ))}
    <p style="margin-top:0.85rem" set:html={terminalToolkitFooter}></p>
  </aside>
</div>

<!-- Data island read by the inline script. We re-read these on every
     astro:page-load so the script picks up changes without depending on
     define:vars (which only runs once across view transitions). -->
<div
  id="terminal-data"
  hidden
  data-projects={JSON.stringify(projectIndex)}
  data-intro={JSON.stringify(terminalIntro)}
  data-help={JSON.stringify(terminalHelp)}
  data-prompt={promptPrefix}
></div>

<script>
  type ProjectEntry = { slug: string; label: string };

  function readJsonAttr<T>(el: HTMLElement | null, attr: string, fallback: T): T {
    try {
      const raw = el?.getAttribute(attr);
      if (!raw) return fallback;
      return JSON.parse(raw) as T;
    } catch {
      return fallback;
    }
  }

  function init() {
    const dataEl = document.getElementById('terminal-data');
    if (!dataEl) return;

    const container = document.getElementById('cmd-content');
    if (!container) return;

    const projects = readJsonAttr<ProjectEntry[]>(dataEl, 'data-projects', []);
    const intro = readJsonAttr<string[]>(dataEl, 'data-intro', []);
    const helpLines = readJsonAttr<string[]>(dataEl, 'data-help', []);
    const promptPrefix = dataEl.getAttribute('data-prompt') || '$ ';

    const projectRoutes: Record<string, string> = Object.fromEntries(
      projects.map((p) => [p.label.toLowerCase(), `/projects/${p.slug}`])
    );
    const slugRoutes: Record<string, string> = Object.fromEntries(
      projects.map((p) => [p.slug.toLowerCase(), `/projects/${p.slug}`])
    );
    const projectNames = projects.map((p) => p.label);
    let selectedProjectIndex = -1;

    let isTyping = false;
    let stopTyping = false;
    let userHasInteracted = false;
    let activeRunId = 0;

    function escapeHtml(s: string) {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function focusInputSafely(input: HTMLInputElement | null | undefined) {
      if (!input || typeof input.focus !== 'function') return;
      if (!userHasInteracted) return;
      try {
        input.focus({ preventScroll: true });
      } catch {
        input.focus();
      }
    }

    function scrollTerminalToBottom() {
      if (container) container.scrollTop = container.scrollHeight;
    }

    /**
     * Find a project route for an arbitrary user-typed string.
     * Tries exact label, then slug variant, then a "spelling tolerance"
     * pass that strips trailing 'e' from each word — covers iOS
     * autocorrecting "judgement" → "judgment".
     */
    function resolveProjectRoute(target: string): string | null {
      const lower = target.trim().toLowerCase();
      if (!lower) return null;
      if (projectRoutes[lower]) return projectRoutes[lower];

      const hyphenated = lower.replace(/\s+/g, '-');
      if (slugRoutes[hyphenated]) return slugRoutes[hyphenated];
      if (projectRoutes[hyphenated]) return projectRoutes[hyphenated];

      const norm = (s: string) =>
        s
          .toLowerCase()
          .replace(/[^a-z\s-]/g, '')
          .replace(/-/g, ' ')
          .split(/\s+/)
          .map((w) => w.replace(/e$/, ''))
          .join(' ')
          .trim();
      const targetNorm = norm(lower);
      for (const p of projects) {
        if (norm(p.label) === targetNorm || norm(p.slug) === targetNorm) {
          return `/projects/${p.slug}`;
        }
      }
      return null;
    }

    function createPrompt(): HTMLDivElement {
      const prompt = document.createElement('div');
      prompt.className = 'line cmd-prompt-line';

      const prefix = document.createElement('span');
      prefix.className = 'prompt-prefix';
      prefix.textContent = promptPrefix;
      prompt.appendChild(prefix);

      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'cmd-input';
      input.spellcheck = false;
      input.autocomplete = 'off';
      // Mobile-keyboard hardening — kills iOS autocapitalization +
      // autocorrect that turn "cd judgement cut" into "Cd judgment Cut"
      // and break the route lookup.
      input.setAttribute('autocapitalize', 'none');
      input.setAttribute('autocorrect', 'off');
      input.setAttribute('inputmode', 'text');
      input.setAttribute('enterkeyhint', 'go');

      input.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
          event.preventDefault();
          if (event.key === 'ArrowDown') {
            selectedProjectIndex =
              selectedProjectIndex < projectNames.length - 1
                ? selectedProjectIndex + 1
                : 0;
          } else {
            selectedProjectIndex =
              selectedProjectIndex > 0
                ? selectedProjectIndex - 1
                : projectNames.length - 1;
          }
          input.value = `cd ${projectNames[selectedProjectIndex]}`;
          return;
        }

        if (event.key !== 'Enter') return;
        event.preventDefault();
        const command = input.value.trim();
        selectedProjectIndex = -1;
        input.disabled = true;

        const cmdLower = command.toLowerCase();

        if (cmdLower === '' || cmdLower === 'help') {
          helpLines.forEach((line) => appendLine(line));
          nextPrompt();
          return;
        }

        if (cmdLower === 'ls') {
          projects.forEach((project) => appendLine(`▸ ${project.label}`));
          nextPrompt();
          return;
        }

        if (cmdLower === 'clear') {
          if (container) container.innerHTML = '';
          const newPrompt = createPrompt();
          container?.appendChild(newPrompt);
          focusInputSafely(newPrompt.querySelector('input'));
          return;
        }

        if (cmdLower === 'about' || cmdLower === 'stack' || cmdLower === 'contact') {
          const targetEl = document.getElementById(cmdLower);
          if (targetEl) {
            targetEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
            appendLine(`scrolling to ${cmdLower}…`);
          } else {
            appendLine(`section "${cmdLower}" not found`);
          }
          nextPrompt();
          return;
        }

        if (cmdLower.startsWith('cd ')) {
          const targetName = command.slice(3).trim();
          const route = resolveProjectRoute(targetName);
          if (route) {
            appendLine(`opening ${targetName}…`);
            setTimeout(() => (window.location.href = route), 480);
            return;
          }
        }

        appendLine(`The system cannot find the path specified: ${command}`);
        nextPrompt();
      });

      function appendLine(text: string) {
        const line = document.createElement('div');
        line.className = 'line';
        line.textContent = text;
        container?.appendChild(line);
      }

      function nextPrompt() {
        const next = createPrompt();
        container?.appendChild(next);
        focusInputSafely(next.querySelector('input'));
        scrollTerminalToBottom();
      }

      prompt.appendChild(input);
      return prompt;
    }

    async function typeLines(
      target: HTMLElement,
      lines: string[],
      charDelay = 18,
      lineDelay = 220,
      runId = ++activeRunId,
    ) {
      isTyping = true;
      stopTyping = false;
      const cancel = () => (stopTyping = true);
      window.addEventListener('keydown', cancel, { once: true });

      for (const text of lines) {
        if (stopTyping || runId !== activeRunId) break;
        const div = document.createElement('div');
        div.className = 'line';
        target.appendChild(div);
        for (let i = 0; i <= text.length; i++) {
          if (stopTyping || runId !== activeRunId) break;
          div.innerHTML = escapeHtml(text.slice(0, i)) + '<span class="caret"></span>';
          await new Promise((r) => setTimeout(r, charDelay));
        }
        if (runId !== activeRunId) return;
        div.innerHTML = escapeHtml(text);
        if (stopTyping) continue;
        await new Promise((r) => setTimeout(r, lineDelay));
      }

      if (runId !== activeRunId) return;
      isTyping = false;
      target.appendChild(createPrompt());
      scrollTerminalToBottom();
    }

    function markInteracted() {
      if (userHasInteracted) return;
      userHasInteracted = true;
      const lastInput = container?.querySelector(
        'input.cmd-input:not([disabled])',
      ) as HTMLInputElement | null;
      if (lastInput) focusInputSafely(lastInput);
    }
    container.addEventListener('click', markInteracted);
    container.addEventListener('focusin', markInteracted);
    container.addEventListener('touchstart', markInteracted, { passive: true });
    document.querySelector('.cmd-window')?.addEventListener('click', markInteracted);

    /** Run / re-run the typewriter intro. Called on first mount, on
     *  astro:page-load, and via the replay button. */
    function runIntro() {
      activeRunId += 1;
      stopTyping = true;
      if (container) container.innerHTML = '';
      isTyping = false;
      selectedProjectIndex = -1;
      setTimeout(() => {
        if (container) typeLines(container, intro, 14, 180);
      }, 250);
    }

    runIntro();

    document.querySelectorAll<HTMLElement>('[data-cmd-replay]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        runIntro();
      });
    });

    // Re-trigger the intro when the user clicks the brand link to "go home"
    // while already on the home page. Astro's ClientRouter handles full
    // navigations elsewhere via the page-load listener below.
    document
      .querySelectorAll<HTMLAnchorElement>('a.topbar-brand[href="/"]')
      .forEach((a) => {
        a.addEventListener('click', () => {
          // Defer so any same-page scroll completes first
          setTimeout(runIntro, 60);
        });
      });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
