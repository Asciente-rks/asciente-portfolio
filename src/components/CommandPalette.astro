---
import { projects } from '../data/projects';

const items = [
  { label: 'home', sub: 'go to landing', href: '/' },
  ...projects.map((p) => ({ label: `open · ${p.title}`, sub: p.role, href: `/projects/${p.slug}` })),
  { label: 'about', sub: 'scroll to about section', href: '/#about' },
  { label: 'stack', sub: 'scroll to stack section', href: '/#stack' },
  { label: 'contact', sub: 'scroll to contact section', href: '/#contact' },
];
---

<div class="cmdk-overlay" id="cmdk-overlay" aria-hidden="true">
  <div class="cmdk-modal" role="dialog" aria-modal="true" aria-label="Command palette">
    <div class="cmdk-input-row">
      <span class="prompt">▸</span>
      <input
        id="cmdk-input"
        class="cmdk-input"
        placeholder="type to filter — ls, cd <project>, about, stack, contact…"
        autocomplete="off"
        spellcheck="false"
        autocapitalize="none"
        autocorrect="off"
        inputmode="search"
      />
    </div>
    <div id="cmdk-list" class="cmdk-list">
      {items.map((item, i) => (
        <div class="cmdk-item" data-href={item.href} data-label={item.label} data-i={i}>
          <span>
            <strong style="color: var(--accent)">›</strong>
            <span style="margin-left:0.5rem">{item.label}</span>
          </span>
          <span class="right">{item.sub}</span>
        </div>
      ))}
    </div>
    <div class="cmdk-footer">
      <span><span class="kbd">↑</span><span class="kbd">↓</span> navigate</span>
      <span><span class="kbd">↵</span> select</span>
      <span><span class="kbd">esc</span> close</span>
    </div>
  </div>
</div>

<script>
  // ----------------------------------------------------------------------
  // Why init() + an idempotency guard:
  // Astro's <ClientRouter> swaps the page DOM on navigation but module
  // scripts (this file) do NOT re-execute. The previous version captured
  // `overlay`, `input`, `items` at module load — after a view transition
  // those references pointed at the detached old DOM, so clicks on the new
  // ⌘K trigger silently mutated nothing. Now we re-resolve every DOM ref
  // each time the page (re-)mounts.
  //
  // The data-cmdk-init guard on the overlay prevents double-binding when
  // astro:page-load fires for the very first page load (Astro fires it on
  // initial load too) — without the guard the manual init() at the bottom
  // would bind every listener twice.
  // ----------------------------------------------------------------------

  function init() {
    const overlay = document.getElementById('cmdk-overlay');
    if (!overlay || overlay.dataset.cmdkInit === 'true') return;
    overlay.dataset.cmdkInit = 'true';

    const input = document.getElementById('cmdk-input') as HTMLInputElement | null;
    const allItems = Array.from(document.querySelectorAll('.cmdk-item')) as HTMLElement[];
    let activeIndex = 0;

    function visibleItems() {
      return allItems.filter((el) => el.style.display !== 'none');
    }

    function setActive(i: number, list = visibleItems()) {
      list.forEach((el, idx) => el.classList.toggle('is-active', idx === i));
      activeIndex = i;
      list[i]?.scrollIntoView({ block: 'nearest' });
    }

    function open() {
      overlay!.classList.add('is-open');
      overlay!.setAttribute('aria-hidden', 'false');
      if (input) input.value = '';
      allItems.forEach((el) => (el.style.display = ''));
      setActive(0);
      // Don't auto-focus on touch — keeps the keyboard from popping when
      // the user just wants to tap an item.
      const isTouch = window.matchMedia('(pointer: coarse)').matches;
      if (!isTouch) setTimeout(() => input?.focus(), 30);
    }

    function close() {
      overlay!.classList.remove('is-open');
      overlay!.setAttribute('aria-hidden', 'true');
    }

    function navigate() {
      const visible = visibleItems();
      const target = visible[activeIndex] || visible[0];
      const href = target?.dataset.href;
      if (href) window.location.href = href;
    }

    input?.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      allItems.forEach((el) => {
        const label = (el.dataset.label || '').toLowerCase();
        const matches = !q || label.includes(q);
        el.style.display = matches ? '' : 'none';
      });
      activeIndex = 0;
      setActive(0);
    });

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });

    allItems.forEach((el) => {
      el.addEventListener('click', () => {
        const href = el.dataset.href;
        if (href) window.location.href = href;
      });
      el.addEventListener('mouseenter', () => {
        const visible = visibleItems();
        const idx = visible.indexOf(el);
        if (idx >= 0) setActive(idx, visible);
      });
    });

    // Bind triggers that exist in THIS swap. Idempotent per element so a
    // surviving button (rare, but possible with same-page transitions)
    // doesn't accumulate listeners.
    document.querySelectorAll<HTMLElement>('[data-cmdk-trigger]').forEach((btn) => {
      if (btn.dataset.cmdkBound === 'true') return;
      btn.dataset.cmdkBound = 'true';
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        open();
      });
    });

    // Keyboard handler is delegated on document so it works everywhere.
    document.addEventListener('keydown', (e) => {
      const isMac = navigator.platform.toUpperCase().includes('MAC');
      const isCmdK = (isMac ? e.metaKey : e.ctrlKey) && e.key.toLowerCase() === 'k';
      if (isCmdK) {
        e.preventDefault();
        if (overlay!.classList.contains('is-open')) close();
        else open();
        return;
      }
      if (!overlay!.classList.contains('is-open')) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        close();
        return;
      }

      const visible = visibleItems();
      if (!visible.length) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive((activeIndex + 1) % visible.length, visible);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive((activeIndex - 1 + visible.length) % visible.length, visible);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        navigate();
      }
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
