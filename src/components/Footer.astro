---
/**
 * Footer — the contact card at the bottom of every page.
 * All text and links come from src/data/site.ts.
 */
import { siteConfig } from '../data/site';

const year = new Date().getFullYear();
const { contact, identity } = siteConfig;
const mailto = `mailto:${contact.email}`;
---

<section class="footer-section" id="contact">
  <div class="footer-card reveal">
    <p class="eyebrow">{contact.footerEyebrow}</p>
    <h2 class="footer-title">{contact.footerHeading}</h2>
    <p class="footer-line">{contact.footerLine}</p>
    <div class="footer-actions">
      <a href={mailto} class="action-btn is-primary">
        <span>Email me</span>
        <span aria-hidden="true">→</span>
      </a>
      <a href={contact.github} target="_blank" rel="noopener noreferrer" class="action-btn">
        <span>GitHub</span>
        <span aria-hidden="true">↗</span>
      </a>
      <a href={contact.linkedin} target="_blank" rel="noopener noreferrer" class="action-btn">
        <span>LinkedIn</span>
        <span aria-hidden="true">↗</span>
      </a>
    </div>
    <p class="footer-bottom">
      © {year} {identity.fullName} · {identity.roleTitle}
    </p>
  </div>
</section>
