---
const year = new Date().getFullYear();
---

<section class="footer-section" id="contact">
  <div class="footer-card reveal">
    <p class="footer-eyebrow">Reach out</p>
    <h2 class="footer-title">Let's build something that ships at $0/month.</h2>
    <div class="footer-actions">
      <a href="mailto:hello@example.com" class="action-btn">
        <span>email</span>
        <span style="color:var(--accent)">→</span>
      </a>
      <a href="https://github.com/Asciente-rks" target="_blank" rel="noopener noreferrer" class="action-btn">
        <span>github</span>
        <span style="color:var(--accent)">→</span>
      </a>
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="action-btn">
        <span>linkedin</span>
        <span style="color:var(--accent)">→</span>
      </a>
    </div>
    <p class="footer-bottom">
      © {year} Ralph Kenneth F. Sonio · Cloud-Native Backend & QA Engineer
    </p>
  </div>
</section>
