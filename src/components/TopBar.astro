---
import { siteConfig } from '../data/site';
---

<header class="topbar">
  <div class="topbar-inner">
    <a href="/" class="topbar-brand" aria-label="Home">
      <span class="glyph">{siteConfig.brand.glyph}</span>
      <span>{siteConfig.brand.short}</span>
    </a>

    <nav class="topbar-nav">
      <a href="/#projects" class="topbar-link">projects.ls</a>
      <a href="/#stack" class="topbar-link">stack.json</a>
      <a href="/#contact" class="topbar-link">contact.tsx</a>
    </nav>

    <div class="topbar-actions">
      <button class="kbd-hint" data-cmdk-trigger aria-label="Open command palette">
        <span>command</span>
        <span class="kbd">⌘</span>
        <span class="kbd">K</span>
      </button>
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z" />
        </svg>
      </button>
    </div>
  </div>
</header>
